<Project>
    <!--
      2dog.gdextension consumer targets.

      Set TwoDogVariant to select the native variant ('release' default,
      'debug', 'editor'); the 2dog.gdextension.[rid] package targets copy the
      matching libgodot-gdext native next to the app.
    -->
    <PropertyGroup>
        <TwoDogVariant Condition="'$(TwoDogVariant)' == ''">release</TwoDogVariant>
    </PropertyGroup>

    <!-- Embed the variant as assembly metadata: twodog.Engine reads it at
         runtime (DetectVariant) to load the matching libgodot-gdext-<variant>
         native, so a stale or mismatched native fails loudly at load. -->
    <ItemGroup>
        <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
            <_Parameter1>TwoDogVariant</_Parameter1>
            <_Parameter2>$(TwoDogVariant)</_Parameter2>
        </AssemblyAttribute>
    </ItemGroup>
</Project>
