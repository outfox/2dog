<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <RootNamespace>Godot</RootNamespace>
        <AssemblyName>twodog.bindings</AssemblyName>

        <IsPackable>true</IsPackable>
        <PackageId>2dog.bindings</PackageId>
        <Version>$(TwoDogVersion)</Version>
        <Description>GodotSharp-compatible C# bindings for Godot Engine over the GDExtension interface. Generated from extension_api.json - no mono module, no GodotSharp. Part of the 2dog.gdextension stack; usable standalone against any libgodot host.</Description>
        <PackageIcon>icon.png</PackageIcon>
        <PackageReadmeFile>README.md</PackageReadmeFile>
    </PropertyGroup>

    <ItemGroup>
        <None Include="../nuget/icon.png" Pack="true" PackagePath="icon.png" Visible="false"/>
        <None Include="README.md" Pack="true" PackagePath="README.md"/>
        <None Include="../nuget/GODOT_LICENSE.txt" Pack="true" PackagePath="LICENSE.txt" Visible="false"/>
        <None Include="../nuget/GODOT_AUTHORS.md" Pack="true" PackagePath="AUTHORS.md" Visible="false"/>
    </ItemGroup>

</Project>
