<Project>
    <!--
      Shared task for writing version defaults into the dotnet-new template's
      template.json. Used by twodog/twodog.csproj (temporary substitution
      around pack, restored to placeholder tokens after) and
      templates/2dog.Templates.csproj (permanent sync before pack).

      Replacement is keyed on the template symbol name (not the version
      value), so it stays correct even when versions collide or
      prefix-overlap, and is idempotent regardless of the file's current
      state. All three symbols are rewritten in a single read/write pass.
    -->
    <UsingTask TaskName="SetTemplateDefaults" TaskFactory="RoslynCodeTaskFactory"
               AssemblyFile="$(MSBuildToolsPath)/Microsoft.Build.Tasks.Core.dll">
        <ParameterGroup>
            <FilePath ParameterType="System.String" Required="true" />
            <TwoDogVer ParameterType="System.String" Required="true" />
            <NativesVer ParameterType="System.String" Required="true" />
            <GodotVer ParameterType="System.String" Required="true" />
        </ParameterGroup>
        <Task>
            <Using Namespace="System.Text.RegularExpressions" />
            <Code Type="Fragment" Language="cs"><![CDATA[
                var text = File.ReadAllText(FilePath);
                // Replace the defaultValue for each known symbol by matching the JSON key.
                text = System.Text.RegularExpressions.Regex.Replace(text,
                    @"(""twodogVersion""[^}]*""defaultValue"":\s*)""[^""]*""",
                    "${1}\"" + TwoDogVer + "\"");
                text = System.Text.RegularExpressions.Regex.Replace(text,
                    @"(""nativesVersion""[^}]*""defaultValue"":\s*)""[^""]*""",
                    "${1}\"" + NativesVer + "\"");
                text = System.Text.RegularExpressions.Regex.Replace(text,
                    @"(""godotVersion""[^}]*""defaultValue"":\s*)""[^""]*""",
                    "${1}\"" + GodotVer + "\"");
                File.WriteAllText(FilePath, text);
            ]]></Code>
        </Task>
    </UsingTask>
</Project>
