<Project Sdk="Microsoft.NET.Sdk">
    <!--
      Browser (wasm) host: your C# code hosts the Godot engine in the browser.

      Publish:  dotnet publish Company.Product1.web -c Release   (from the
                project root; the root global.json pins a wasm-capable SDK)
      Output:   AppBundle/ - serve with any static file server.

      Requires the wasm-tools workload:  dotnet workload install wasm-tools
      The 2dog.browser-wasm package statically links the Godot engine into
      dotnet.native.wasm during publish and exports the Godot project's
      content as godot.pck (using the desktop editor packages on this machine).
    -->
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <OutputType>Exe</OutputType>
        <RuntimeIdentifier>browser-wasm</RuntimeIdentifier>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <IsPackable>false</IsPackable>
        <!-- Keep host namespaces uniform with the desktop host (whose
             '.2dog' assembly name is not a valid namespace). -->
        <RootNamespace>Company.Product1.Web</RootNamespace>
    </PropertyGroup>
    <!-- Godot project location: the parent directory (hosts are nested inside
         the Godot project, hidden from the Godot editor by their .gdignore) -->
    <PropertyGroup>
        <GodotProjectDir>..</GodotProjectDir>
        <TwoDogRemoveDuplicateGodotAnalyzers>true</TwoDogRemoveDuplicateGodotAnalyzers>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="2dog.engine" Version="TWODOG_PKG_VERSION"/>
        <PackageReference Include="2dog.browser-wasm" Version="[NATIVES_PKG_VERSION]"/>
    </ItemGroup>
    <ItemGroup>
        <ProjectReference Include="../TPLRAWNAME.csproj"/>
    </ItemGroup>

    <!-- Root the game assembly: scripts are resolved by reflection. Add a
         TrimmerRootAssembly for any NuGet package your game code reaches via
         reflection (e.g. an ECS or serializer library). -->
    <ItemGroup>
        <TrimmerRootAssembly Include="TPLRAWNAME"/>
        <TrimmerRootAssembly Include="$(TargetName)"/>
    </ItemGroup>

    <Target Name="DeepClean" AfterTargets="Clean">
        <RemoveDir Directories="AppBundle"/>
    </Target>
</Project>
