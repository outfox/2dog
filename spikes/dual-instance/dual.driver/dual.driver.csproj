<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <IsPackable>false</IsPackable>
        <!-- Emits deps.json so the host's AssemblyDependencyResolver can load
             this assembly (and twodog.*) into a per-instance ALC. -->
        <EnableDynamicLoading>true</EnableDynamicLoading>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\..\twodog.bindings\twodog.bindings.csproj" />
        <ProjectReference Include="..\..\..\twodog.gdextension\twodog.gdextension.csproj" />
    </ItemGroup>

</Project>
