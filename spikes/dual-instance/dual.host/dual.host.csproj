<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <!-- Build ordering only: the host must never load Godot types into the
         default ALC; it locates dual.driver.dll at runtime and loads it into
         per-instance ALCs. -->
    <ItemGroup>
        <ProjectReference Include="..\dual.driver\dual.driver.csproj" ReferenceOutputAssembly="false" />
    </ItemGroup>

</Project>
