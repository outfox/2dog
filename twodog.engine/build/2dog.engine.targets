<Project>
    <!--
      TwoDog MSBuild Targets

      Handles copying GodotPlugins assemblies to output directory.
      GodotSharp and Godot.SourceGenerators are bundled in the 2dog.engine package
      (lib/net10.0/ and analyzers/dotnet/cs/ respectively).

      Native libraries are provided by separate platform-specific packages:
        - 2dog.win-x64 / 2dog.linux-x64 / 2dog.osx-arm64: template_release builds
        - 2dog.win-x64.debug / 2dog.linux-x64.debug / 2dog.osx-arm64.debug: template_debug builds
        - 2dog.win-x64.editor / 2dog.linux-x64.editor / 2dog.osx-arm64.editor: editor builds

      When you install the 2dog.engine package from NuGet, the release variant platform
      packages above are referenced automatically. For debug/editor variants you
      can reference the corresponding platform packages explicitly.

      Configurable Properties (in consuming project):
        - TwoDogVariant: 'release' (default), 'debug', or 'editor'
          Selects the native libgodot variant (via the platform meta package
          targets) AND the GodotPlugins layout. Also embedded as assembly
          metadata so twodog's DllImportResolver loads the matching
          libgodot-<variant> library at runtime.
        - TwoDogBuildType: 'template_release', 'template_debug', or 'editor'
          Advanced: override the build type used for API placement.
    -->

    <!-- ============================================ -->
    <!-- GodotProjectDir Assembly Metadata             -->
    <!-- ============================================ -->
    <!-- Embed GodotProjectDir as assembly metadata so twodog can resolve the
         Godot project directory at runtime (via Engine.ResolveProjectDir()).
         Consumers just need <GodotProjectDir> in their .csproj. -->
    <ItemGroup Condition="'$(GodotProjectDir)' != ''">
        <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
            <_Parameter1>GodotProjectDir</_Parameter1>
            <!-- We use the single-parameter overload of GetFullPath with Combine to be .NET Framework-compatible -->
            <!-- This is important for VS users, where processes are still hosted in .NET Fx -->
            <_Parameter2>$([System.IO.Path]::GetFullPath($([System.IO.Path]::Combine('$(MSBuildProjectDirectory)', '$(GodotProjectDir)'))))</_Parameter2>
        </AssemblyAttribute>
    </ItemGroup>

    <!-- ============================================ -->
    <!-- Variant & Build Type Configuration           -->
    <!-- ============================================ -->
    <PropertyGroup>
        <!-- Variant: release (default), debug, or editor -->
        <TwoDogVariant Condition="'$(TwoDogVariant)' == ''">release</TwoDogVariant>

        <!-- Map variant to build type for API assembly handling -->
        <TwoDogBuildType Condition="'$(TwoDogBuildType)' == '' And '$(TwoDogVariant)' == 'release'">template_release</TwoDogBuildType>
        <TwoDogBuildType Condition="'$(TwoDogBuildType)' == '' And '$(TwoDogVariant)' == 'debug'">template_debug</TwoDogBuildType>
        <TwoDogBuildType Condition="'$(TwoDogBuildType)' == '' And '$(TwoDogVariant)' == 'editor'">editor</TwoDogBuildType>
        <TwoDogBuildType Condition="'$(TwoDogBuildType)' == ''">template_release</TwoDogBuildType>

        <!-- Package root (for locating contentFiles when used as a NuGet package) -->
        <TwoDogPackageRoot Condition="'$(TwoDogPackageRoot)' == ''">$(MSBuildThisFileDirectory)../</TwoDogPackageRoot>
    </PropertyGroup>

    <!-- Embed the variant as assembly metadata: twodog's DllImportResolver
         reads it at runtime to load the matching libgodot-<variant> native.
         A stale or mismatched native then fails loudly at load instead of
         producing an opaque hostfxr initialization error. -->
    <ItemGroup>
        <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
            <_Parameter1>TwoDogVariant</_Parameter1>
            <_Parameter2>$(TwoDogVariant)</_Parameter2>
        </AssemblyAttribute>
    </ItemGroup>

    <!-- Hosts that reference both a Godot.NET.Sdk game project and 2dog.engine
         would otherwise receive Godot.SourceGenerators twice. Keep this opt-in:
         the game project itself must retain its generator. -->
    <Target Name="TwoDogRemoveDuplicateGodotAnalyzers"
            BeforeTargets="CoreCompile"
            Condition="'$(TwoDogRemoveDuplicateGodotAnalyzers)' == 'true'">
        <ItemGroup>
            <Analyzer Remove="@(Analyzer)"
                      Condition="$([System.String]::Copy('%(Analyzer.Identity)').Contains('Godot.SourceGenerators'))" />
        </ItemGroup>
    </Target>

    <!-- ============================================ -->
    <!-- GodotPlugins Configuration                   -->
    <!-- ============================================ -->
    <PropertyGroup>
        <!--
          GodotPlugins placement depends on build type:
          - Editor builds (TOOLS_ENABLED): Nested GodotSharp/Api/Debug/ structure
          - Template builds (LIBGODOT_HOSTFXR): Flat structure in output dir
        -->

        <!-- 1. GODOTSHARP_DIR env var (highest priority) -->
        <TwoDogGodotApiSourcePath Condition="'$(GODOTSHARP_DIR)' != '' And Exists('$(GODOTSHARP_DIR)/GodotPlugins.dll')">$(GODOTSHARP_DIR)</TwoDogGodotApiSourcePath>

        <!-- 2. Path within the NuGet package (for package consumers) -->
        <TwoDogGodotApiSourcePath_Package>$(TwoDogPackageRoot)build/api/</TwoDogGodotApiSourcePath_Package>
        <TwoDogGodotApiSourcePath Condition="'$(TwoDogGodotApiSourcePath)' == '' And Exists('$(TwoDogGodotApiSourcePath_Package)GodotPlugins.dll')">$(TwoDogGodotApiSourcePath_Package)</TwoDogGodotApiSourcePath>

        <!-- 3. Path for project reference consumers (source checkout) -->
        <TwoDogGodotApiSourcePath_ProjectRef>$(MSBuildThisFileDirectory)../../godot/bin/GodotSharp/Api/Debug/</TwoDogGodotApiSourcePath_ProjectRef>
        <TwoDogGodotApiSourcePath Condition="'$(TwoDogGodotApiSourcePath)' == '' And Exists('$(TwoDogGodotApiSourcePath_ProjectRef)')">$(TwoDogGodotApiSourcePath_ProjectRef)</TwoDogGodotApiSourcePath>

        <!--
          Destination path depends on build type:
          - Editor builds (TOOLS_ENABLED): GodotSharp/Api/Debug/ subdirectory
          - Template builds (LIBGODOT_HOSTFXR without TOOLS_ENABLED, i.e. both
            template_debug and template_release): flat in the output directory
            (the native resolves the API assemblies dir as exe_dir)
        -->
        <TwoDogGodotApiDestSubdir Condition="'$(TwoDogBuildType)' == 'editor'">GodotSharp/Api/Debug/</TwoDogGodotApiDestSubdir>
        <TwoDogGodotApiDestSubdir Condition="'$(TwoDogGodotApiDestSubdir)' == ''"></TwoDogGodotApiDestSubdir>
    </PropertyGroup>

    <!-- ============================================ -->
    <!-- Target: Copy GodotPlugins to Output          -->
    <!-- ============================================ -->
    <!-- TwoDogSkipGodotApiCopy: set 'true' to suppress the GodotPlugins file
         copies entirely (browser-wasm publishes set this - on web there is no
         GodotPlugins.dll on disk; plugin init flows through a registered
         function pointer instead). -->
    <Target Name="TwoDogCopyGodotApi"
            AfterTargets="Build"
            Condition="'$(DesignTimeBuild)' != 'true' And '$(TwoDogSkipGodotApiCopy)' != 'true' And '$(TwoDogGodotApiSourcePath)' != '' And Exists('$(TwoDogGodotApiSourcePath)')">

        <PropertyGroup>
            <TwoDogGodotApiDestPath>$(OutputPath)$(TwoDogGodotApiDestSubdir)</TwoDogGodotApiDestPath>
        </PropertyGroup>

        <ItemGroup>
            <TwoDogGodotApiFiles Include="$(TwoDogGodotApiSourcePath)GodotPlugins.dll"/>
            <TwoDogGodotApiFiles Include="$(TwoDogGodotApiSourcePath)GodotPlugins.pdb" Condition="Exists('$(TwoDogGodotApiSourcePath)GodotPlugins.pdb')"/>
            <TwoDogGodotApiFiles Include="$(TwoDogGodotApiSourcePath)GodotPlugins.runtimeconfig.json" Condition="Exists('$(TwoDogGodotApiSourcePath)GodotPlugins.runtimeconfig.json')"/>
        </ItemGroup>

        <MakeDir Directories="$(TwoDogGodotApiDestPath)" Condition="'$(TwoDogGodotApiDestSubdir)' != ''"/>
        <Copy SourceFiles="@(TwoDogGodotApiFiles)"
              DestinationFolder="$(TwoDogGodotApiDestPath)"
              SkipUnchangedFiles="true"/>

        <Message Importance="normal" Text="TwoDog: Copied GodotPlugins to $(TwoDogGodotApiDestPath)"/>
    </Target>

    <!-- ============================================ -->
    <!-- Target: Publish GodotPlugins                 -->
    <!-- ============================================ -->
    <Target Name="TwoDogPublishGodotApi"
            AfterTargets="Publish"
            Condition="'$(DesignTimeBuild)' != 'true' And '$(TwoDogSkipGodotApiCopy)' != 'true' And '$(TwoDogGodotApiSourcePath)' != '' And Exists('$(TwoDogGodotApiSourcePath)')">

        <PropertyGroup>
            <TwoDogGodotApiPublishDestPath>$(PublishDir)$(TwoDogGodotApiDestSubdir)</TwoDogGodotApiPublishDestPath>
        </PropertyGroup>

        <ItemGroup>
            <TwoDogGodotApiFilesForPublish Include="$(TwoDogGodotApiSourcePath)GodotPlugins.dll"/>
            <TwoDogGodotApiFilesForPublish Include="$(TwoDogGodotApiSourcePath)GodotPlugins.pdb" Condition="Exists('$(TwoDogGodotApiSourcePath)GodotPlugins.pdb')"/>
            <TwoDogGodotApiFilesForPublish Include="$(TwoDogGodotApiSourcePath)GodotPlugins.runtimeconfig.json" Condition="Exists('$(TwoDogGodotApiSourcePath)GodotPlugins.runtimeconfig.json')"/>
        </ItemGroup>

        <MakeDir Directories="$(TwoDogGodotApiPublishDestPath)" Condition="'$(TwoDogGodotApiDestSubdir)' != ''"/>
        <Copy SourceFiles="@(TwoDogGodotApiFilesForPublish)"
              DestinationFolder="$(TwoDogGodotApiPublishDestPath)"
              SkipUnchangedFiles="true"/>

        <Message Importance="high" Text="TwoDog: Published GodotPlugins to $(TwoDogGodotApiPublishDestPath)"/>
    </Target>

    <!-- ============================================ -->
    <!-- Automatic Godot Project Import               -->
    <!-- ============================================ -->
    <!--
      Runs the Godot editor's headless import pipeline against
      $(GodotProjectDir) when its source files changed. Generates .uid files
      for C# scripts, imports textures/meshes, and builds the .godot/ cache
      (script UID cache); without it the engine logs a startup error.

      Uses the 2dog import helper (tools/net10.0/2dog.import.dll) against the
      editor-variant libgodot from the 2dog.<rid>.editor package; no external
      Godot editor installation required. An explicitly configured external
      editor ($(GodotEditor) property or GODOT_EDITOR env var) takes precedence.

      Properties:
        TwoDogAutoImport:      'true' (default) / 'false' to disable
        TwoDogRequireImport:   'true' turns the missing-capability warning into an error
        TwoDogForceImport:     'true' forces the import to run even if up-to-date
        TwoDogImportStampFile: override the stamp file location
        TwoDogImportExcludes:  extra semicolon-separated glob excludes for the
                               import inputs (dirs with a .gdignore are always
                               excluded, mirroring the Godot importer)
        GodotEditor:           path to an external Godot editor binary
    -->
    <PropertyGroup>
        <TwoDogAutoImport Condition="'$(TwoDogAutoImport)' == ''">true</TwoDogAutoImport>
        <TwoDogGodotProjectFullPath Condition="'$(GodotProjectDir)' != ''">$([System.IO.Path]::GetFullPath($([System.IO.Path]::Combine('$(MSBuildProjectDirectory)', '$(GodotProjectDir)'))))</TwoDogGodotProjectFullPath>
        <!-- Stamp lives inside the game project's .godot/ dir: it is shared by
             all consuming projects (one import per game project, not one per
             consumer), and deleting .godot/ - the standard "force reimport"
             gesture - invalidates it. -->
        <TwoDogImportStampFile Condition="'$(TwoDogImportStampFile)' == '' And '$(TwoDogGodotProjectFullPath)' != ''">$(TwoDogGodotProjectFullPath)/.godot/2dog.import.stamp</TwoDogImportStampFile>
        <!-- Import helper: package layout first, then source-checkout build output -->
        <TwoDogImportHelperPath Condition="'$(TwoDogImportHelperPath)' == '' And Exists('$(MSBuildThisFileDirectory)../tools/net10.0/2dog.import.dll')">$(MSBuildThisFileDirectory)../tools/net10.0/2dog.import.dll</TwoDogImportHelperPath>
        <TwoDogImportHelperPath Condition="'$(TwoDogImportHelperPath)' == '' And Exists('$(MSBuildThisFileDirectory)../../twodog.import/bin/Release/net10.0/2dog.import.dll')">$(MSBuildThisFileDirectory)../../twodog.import/bin/Release/net10.0/2dog.import.dll</TwoDogImportHelperPath>
        <TwoDogImportHelperPath Condition="'$(TwoDogImportHelperPath)' == '' And Exists('$(MSBuildThisFileDirectory)../../twodog.import/bin/Debug/net10.0/2dog.import.dll')">$(MSBuildThisFileDirectory)../../twodog.import/bin/Debug/net10.0/2dog.import.dll</TwoDogImportHelperPath>
        <_TwoDogDotNetHost>$(DOTNET_HOST_PATH)</_TwoDogDotNetHost>
        <_TwoDogDotNetHost Condition="'$(_TwoDogDotNetHost)' == ''">dotnet</_TwoDogDotNetHost>
    </PropertyGroup>

    <ItemGroup Condition="'$(TwoDogGodotProjectFullPath)' != '' And '$(TwoDogAutoImport)' == 'true'">
        <!-- .uid files are excluded (purely generated). *.import files are
             intentionally INCLUDED: they are user-editable import settings
             whose changes must retrigger the import. Safe because the stamp
             is touched after the import completes, so files (re)generated
             during the run are always older than the stamp.

             Directories carrying a .gdignore (e.g. nested 2dog host projects)
             are invisible to the Godot editor/importer, so their churn must
             not invalidate the import stamp either. TwoDogImportExcludes:
             extra semicolon-separated glob excludes supplied by the user. -->
        <_TwoDogGdIgnoredDirs Include="$(TwoDogGodotProjectFullPath)/**/.gdignore"/>
        <TwoDogImportInputs Include="$(TwoDogGodotProjectFullPath)/**/*"
                            Exclude="$(TwoDogGodotProjectFullPath)/.godot/**;$(TwoDogGodotProjectFullPath)/bin/**;$(TwoDogGodotProjectFullPath)/obj/**;$(TwoDogGodotProjectFullPath)/**/*.uid;$(TwoDogGodotProjectFullPath)/**/*.tmp;$(TwoDogGodotProjectFullPath)/**/.DS_Store;@(_TwoDogGdIgnoredDirs->'%(RootDir)%(Directory)**');$(TwoDogImportExcludes)"/>
    </ItemGroup>

    <!-- Deleting the stamp before the incremental check forces the import.
         Also covers staleness that Inputs/Outputs cannot see (deleted assets). -->
    <Target Name="TwoDogForceImport"
            BeforeTargets="TwoDogImportGodotProject"
            Condition="'$(TwoDogForceImport)' == 'true' And '$(TwoDogImportStampFile)' != ''">
        <Delete Files="$(TwoDogImportStampFile)"/>
    </Target>

    <Target Name="TwoDogImportGodotProject"
            AfterTargets="Build"
            Inputs="@(TwoDogImportInputs)"
            Outputs="$(TwoDogImportStampFile)"
            Condition="'$(DesignTimeBuild)' != 'true' And '$(TwoDogAutoImport)' == 'true' And '$(TwoDogGodotProjectFullPath)' != '' And Exists('$(TwoDogGodotProjectFullPath)/project.godot')">

        <!-- Capability resolution happens inside the target body: the platform
             and tools package targets that provide these properties may be
             imported after this file, so evaluation-time references here would
             be import-order dependent; execution time is not. -->
        <PropertyGroup>
            <_TwoDogImportEditor>$(GodotEditor)</_TwoDogImportEditor>
            <_TwoDogImportEditor Condition="'$(_TwoDogImportEditor)' == ''">$(GODOT_EDITOR)</_TwoDogImportEditor>
            <!-- GodotTools: 2dog.tools package, or the source checkout -->
            <_TwoDogToolsDir>$(TwoDogGodotToolsDir)</_TwoDogToolsDir>
            <_TwoDogToolsDir Condition="'$(_TwoDogToolsDir)' == '' And Exists('$(MSBuildThisFileDirectory)../../godot/bin/GodotSharp/Tools/GodotTools.dll')">$(MSBuildThisFileDirectory)../../godot/bin/GodotSharp/Tools/</_TwoDogToolsDir>
            <_TwoDogCanUseHelper>false</_TwoDogCanUseHelper>
            <_TwoDogCanUseHelper Condition="'$(TwoDogImportHelperPath)' != '' And '$(TwoDogEditorLibGodotPath)' != '' And Exists('$(TwoDogEditorLibGodotPath)') And '$(_TwoDogToolsDir)' != '' And '$(TwoDogGodotApiSourcePath)' != ''">true</_TwoDogCanUseHelper>
            <!-- Directory args must not end in a backslash: a trailing '\'
                 before the closing quote escapes it on Windows command lines. -->
            <_TwoDogToolsDirArg>$(_TwoDogToolsDir.TrimEnd('\').TrimEnd('/'))</_TwoDogToolsDirArg>
            <_TwoDogApiDirArg>$(TwoDogGodotApiSourcePath.TrimEnd('\').TrimEnd('/'))</_TwoDogApiDirArg>
        </PropertyGroup>

        <!-- IgnoreStandardErrorWarningFormat: Godot prints non-fatal
             "ERROR:"/"WARNING:"-formatted lines during imports, which Exec
             would otherwise promote to build errors even on exit code 0.
             Success is judged by the exit code alone. -->

        <!-- (1) explicitly configured external editor -->
        <Exec Condition="'$(_TwoDogImportEditor)' != ''"
              Command="&quot;$(_TwoDogImportEditor)&quot; --headless --import --path &quot;$(TwoDogGodotProjectFullPath)&quot;"
              IgnoreStandardErrorWarningFormat="true"/>

        <!-- (2) in-process import helper against the packaged editor libgodot -->
        <Exec Condition="'$(_TwoDogImportEditor)' == '' And '$(_TwoDogCanUseHelper)' == 'true'"
              Command="&quot;$(_TwoDogDotNetHost)&quot; exec &quot;$(TwoDogImportHelperPath)&quot; --libgodot &quot;$(TwoDogEditorLibGodotPath)&quot; --api-dir &quot;$(_TwoDogApiDirArg)&quot; --tools-dir &quot;$(_TwoDogToolsDirArg)&quot; &quot;$(TwoDogGodotProjectFullPath)&quot;"
              EnvironmentVariables="GODOTSHARP_DIR=$(_TwoDogApiDirArg);GODOT_TOOLS_DIR=$(_TwoDogToolsDirArg)"
              IgnoreStandardErrorWarningFormat="true"/>

        <!-- (3) nothing available: warn and skip (or error when required) -->
        <Warning Condition="'$(_TwoDogImportEditor)' == '' And '$(_TwoDogCanUseHelper)' != 'true' And '$(TwoDogRequireImport)' != 'true'"
                 Text="TwoDog: Godot project '$(TwoDogGodotProjectFullPath)' needs a resource import, but no import capability was found (editor libgodot='$(TwoDogEditorLibGodotPath)', helper='$(TwoDogImportHelperPath)', tools='$(_TwoDogToolsDir)'). The application may log a startup error about missing .uid files. Set &lt;GodotEditor&gt; to a Godot editor binary, or restore the 2dog.&lt;rid&gt;.editor and 2dog.tools packages. Set &lt;TwoDogAutoImport&gt;false&lt;/TwoDogAutoImport&gt; to silence this warning."/>
        <Error Condition="'$(_TwoDogImportEditor)' == '' And '$(_TwoDogCanUseHelper)' != 'true' And '$(TwoDogRequireImport)' == 'true'"
               Text="TwoDog: import required (TwoDogRequireImport=true) but no import capability is available (editor libgodot='$(TwoDogEditorLibGodotPath)', helper='$(TwoDogImportHelperPath)', tools='$(_TwoDogToolsDir)')."/>

        <!-- Stamp only when an import actually ran, so a skipped import retries next build -->
        <MakeDir Directories="$(TwoDogGodotProjectFullPath)/.godot" Condition="'$(_TwoDogImportEditor)' != '' Or '$(_TwoDogCanUseHelper)' == 'true'"/>
        <Touch Files="$(TwoDogImportStampFile)" AlwaysCreate="true" Condition="'$(_TwoDogImportEditor)' != '' Or '$(_TwoDogCanUseHelper)' == 'true'"/>
        <Message Importance="high" Text="TwoDog: Imported Godot project $(TwoDogGodotProjectFullPath)" Condition="'$(_TwoDogImportEditor)' != '' Or '$(_TwoDogCanUseHelper)' == 'true'"/>
    </Target>

</Project>
