<Project>
    <!--
      2dog.gdextension macOS arm64 Meta Package Targets

      Parameter block for the shared native resolver
      (2dog.native-resolver.targets, shipped alongside this file): declares
      where this package's non-mono natives live and how they are named. The
      shared targets resolve the $(TwoDogVariant) native - NuGet package
      first, local godot/bin fallback (extra_suffix=gdext_shared_library) -
      and copy it to output/publish as libgodot-gdext-<variant>.dylib.
    -->
    <PropertyGroup>
        <_TwoDogGdextOsxArm64TargetsDir>$(MSBuildThisFileDirectory.TrimEnd('\').TrimEnd('/'))</_TwoDogGdextOsxArm64TargetsDir>
        <TwoDogGdextOsxArm64PackageVersion Condition="'$(TwoDogGdextOsxArm64PackageVersion)' == ''">$([System.IO.Path]::GetFileName($([System.IO.Path]::GetDirectoryName('$(_TwoDogGdextOsxArm64TargetsDir)'))))</TwoDogGdextOsxArm64PackageVersion>
        <TwoDogLocalGodotBin Condition="'$(TwoDogLocalGodotBin)' == ''">$(MSBuildThisFileDirectory)../../../godot/bin/</TwoDogLocalGodotBin>
    </PropertyGroup>

    <ItemGroup>
        <TwoDogNativeResolver Include="osx-arm64">
            <PackageId>2dog.gdextension.osx-arm64</PackageId>
            <PackageVersion>$(TwoDogGdextOsxArm64PackageVersion)</PackageVersion>
            <LibPrefix>libgodot-gdext</LibPrefix>
            <Ext>dylib</Ext>
            <HostOs>OSX</HostOs>
            <RidPrefix>osx</RidPrefix>
            <LocalBin>$(TwoDogLocalGodotBin)</LocalBin>
            <LocalRelease>libgodot.macos.template_release.arm64.gdext_shared_library.dylib</LocalRelease>
            <LocalDebug>libgodot.macos.template_debug.arm64.gdext_shared_library.dylib</LocalDebug>
            <LocalEditor>libgodot.macos.editor.arm64.gdext_shared_library.dylib</LocalEditor>
        </TwoDogNativeResolver>
    </ItemGroup>

    <Import Project="$(MSBuildThisFileDirectory)2dog.native-resolver.targets"
            Condition="'$(_TwoDogNativeResolverImported)' != 'true' And Exists('$(MSBuildThisFileDirectory)2dog.native-resolver.targets')"/>
    <Import Project="$(MSBuildThisFileDirectory)../../common/2dog.native-resolver.targets"
            Condition="'$(_TwoDogNativeResolverImported)' != 'true'"/>
</Project>
