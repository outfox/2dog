<Project Sdk="Microsoft.NET.Sdk">
    <!-- Platform-specific configuration (GDExtension flavor: non-mono natives) -->
    <PropertyGroup>
        <GdExtension>true</GdExtension>
        <PlatformRID>osx-arm64</PlatformRID>
        <PlatformOS>macos</PlatformOS>
        <PlatformArch>arm64</PlatformArch>
        <BuildVariant>template_debug</BuildVariant>
        <NativeLibExt>dylib</NativeLibExt>
        <PackageSuffix>.debug</PackageSuffix>
        <Description>macOS arm64 debug native libgodot-gdext library for 2dog.gdextension. Reference this package alongside 2dog.gdextension for macOS debug support.</Description>
    </PropertyGroup>
</Project>
