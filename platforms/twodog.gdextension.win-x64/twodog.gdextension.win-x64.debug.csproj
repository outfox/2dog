<Project Sdk="Microsoft.NET.Sdk">
    <!-- Platform-specific configuration (GDExtension flavor: non-mono natives) -->
    <PropertyGroup>
        <GdExtension>true</GdExtension>
        <PlatformRID>win-x64</PlatformRID>
        <PlatformOS>windows</PlatformOS>
        <BuildVariant>template_debug</BuildVariant>
        <NativeLibExt>dll</NativeLibExt>
        <PackageSuffix>.debug</PackageSuffix>
        <Description>Windows x64 debug native libgodot-gdext library for 2dog.gdextension. Reference this package alongside 2dog.gdextension for Windows debug support.</Description>
    </PropertyGroup>
</Project>
