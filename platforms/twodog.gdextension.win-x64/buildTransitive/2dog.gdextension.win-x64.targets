<Project>
    <!--
      2dog.gdextension Windows x64 Meta Package Targets

      Owns all native libgodot-gdext-*.dll copy logic (non-mono natives for the
      GDExtension-based 2dog stack; the mono-based 2dog.engine stack ships its
      own libgodot-*.dll via 2dog.win-x64).

      Behaviour:
      - When consumed as a NuGet package, it locates the appropriate
        libgodot-gdext dll from the variant dependency packages in the global
        NuGet package cache and copies it to the output/publish directory.
      - When used via ProjectReference in this repository, it falls back to the
        locally built non-mono Godot binaries in godot/bin
        (extra_suffix=gdext_shared_library).

      Variant selection: $(TwoDogVariant) ('release' default, 'debug', 'editor').
    -->

    <PropertyGroup>
        <_TwoDogGdextWinX64TargetsDir>$(MSBuildThisFileDirectory.TrimEnd('\').TrimEnd('/'))</_TwoDogGdextWinX64TargetsDir>
        <TwoDogGdextWinX64PackageVersion Condition="'$(TwoDogGdextWinX64PackageVersion)' == ''">$([System.IO.Path]::GetFileName($([System.IO.Path]::GetDirectoryName('$(_TwoDogGdextWinX64TargetsDir)'))))</TwoDogGdextWinX64PackageVersion>
    </PropertyGroup>

    <!-- Variant package and local library locations -->
    <PropertyGroup>
        <TwoDogGdextWinX64ReleasePackage>$(NuGetPackageRoot)/2dog.gdextension.win-x64.release/$(TwoDogGdextWinX64PackageVersion)/runtimes/win-x64/native/libgodot-gdext-release.dll</TwoDogGdextWinX64ReleasePackage>
        <TwoDogGdextWinX64DebugPackage>$(NuGetPackageRoot)/2dog.gdextension.win-x64.debug/$(TwoDogGdextWinX64PackageVersion)/runtimes/win-x64/native/libgodot-gdext-debug.dll</TwoDogGdextWinX64DebugPackage>
        <TwoDogGdextWinX64EditorPackage>$(NuGetPackageRoot)/2dog.gdextension.win-x64.editor/$(TwoDogGdextWinX64PackageVersion)/runtimes/win-x64/native/libgodot-gdext-editor.dll</TwoDogGdextWinX64EditorPackage>

        <TwoDogLocalGodotBin Condition="'$(TwoDogLocalGodotBin)' == ''">$(MSBuildThisFileDirectory)../../../godot/bin/</TwoDogLocalGodotBin>
        <TwoDogGdextWinX64ReleaseLocal>$(TwoDogLocalGodotBin)godot.windows.template_release.x86_64.gdext_shared_library.dll</TwoDogGdextWinX64ReleaseLocal>
        <TwoDogGdextWinX64DebugLocal>$(TwoDogLocalGodotBin)godot.windows.template_debug.x86_64.gdext_shared_library.dll</TwoDogGdextWinX64DebugLocal>
        <TwoDogGdextWinX64EditorLocal>$(TwoDogLocalGodotBin)godot.windows.editor.x86_64.gdext_shared_library.dll</TwoDogGdextWinX64EditorLocal>
    </PropertyGroup>

    <!-- Preferred variant follows $(TwoDogVariant); 'release' when unset. -->
    <PropertyGroup>
        <TwoDogGdextWinX64PreferredVariant Condition="'$(TwoDogGdextWinX64PreferredVariant)' == ''">$(TwoDogVariant)</TwoDogGdextWinX64PreferredVariant>
        <TwoDogGdextWinX64PreferredVariant Condition="'$(TwoDogGdextWinX64PreferredVariant)' == ''">release</TwoDogGdextWinX64PreferredVariant>
    </PropertyGroup>

    <PropertyGroup>
        <TwoDogGdextWinX64VariantPackagePath Condition="'$(TwoDogGdextWinX64PreferredVariant)' == 'editor'">$(TwoDogGdextWinX64EditorPackage)</TwoDogGdextWinX64VariantPackagePath>
        <TwoDogGdextWinX64VariantPackagePath Condition="'$(TwoDogGdextWinX64PreferredVariant)' == 'debug'">$(TwoDogGdextWinX64DebugPackage)</TwoDogGdextWinX64VariantPackagePath>
        <TwoDogGdextWinX64VariantPackagePath Condition="'$(TwoDogGdextWinX64PreferredVariant)' == 'release'">$(TwoDogGdextWinX64ReleasePackage)</TwoDogGdextWinX64VariantPackagePath>

        <TwoDogGdextWinX64VariantLocalPath Condition="'$(TwoDogGdextWinX64PreferredVariant)' == 'editor'">$(TwoDogGdextWinX64EditorLocal)</TwoDogGdextWinX64VariantLocalPath>
        <TwoDogGdextWinX64VariantLocalPath Condition="'$(TwoDogGdextWinX64PreferredVariant)' == 'debug'">$(TwoDogGdextWinX64DebugLocal)</TwoDogGdextWinX64VariantLocalPath>
        <TwoDogGdextWinX64VariantLocalPath Condition="'$(TwoDogGdextWinX64PreferredVariant)' == 'release'">$(TwoDogGdextWinX64ReleaseLocal)</TwoDogGdextWinX64VariantLocalPath>
    </PropertyGroup>

    <!-- Resolve final native library path: prefer NuGet package, fall back to local -->
    <PropertyGroup>
        <TwoDogGdextWinX64NativeLib Condition="'$(TwoDogGdextWinX64VariantPackagePath)' != '' And Exists('$(TwoDogGdextWinX64VariantPackagePath)')">$(TwoDogGdextWinX64VariantPackagePath)</TwoDogGdextWinX64NativeLib>
        <TwoDogGdextWinX64NativeLib Condition="'$(TwoDogGdextWinX64NativeLib)' == '' And '$(TwoDogGdextWinX64VariantLocalPath)' != '' And Exists('$(TwoDogGdextWinX64VariantLocalPath)')">$(TwoDogGdextWinX64VariantLocalPath)</TwoDogGdextWinX64NativeLib>
    </PropertyGroup>

    <Target Name="TwoDogGdextWinX64DiagnosticCheck"
            BeforeTargets="Build"
            Condition="'$(DesignTimeBuild)' != 'true' And $([MSBuild]::IsOSPlatform('Windows')) And '$(TwoDogGdextWinX64NativeLib)' == ''">
        <Warning Text="2dog.gdextension: Could not locate libgodot-gdext.dll for win-x64. Searched NuGet: $(TwoDogGdextWinX64VariantPackagePath) — Local: $(TwoDogGdextWinX64VariantLocalPath). The application will fail at runtime with DllNotFoundException." />
    </Target>

    <Target Name="TwoDogGdextWinX64CopyNatives"
            AfterTargets="Build"
            Condition="'$(DesignTimeBuild)' != 'true' And $([MSBuild]::IsOSPlatform('Windows')) And '$(TwoDogGdextWinX64NativeLib)' != '' And Exists('$(TwoDogGdextWinX64NativeLib)')">
        <Copy SourceFiles="$(TwoDogGdextWinX64NativeLib)"
              DestinationFiles="$(OutputPath)libgodot-gdext-$(TwoDogGdextWinX64PreferredVariant).dll"
              SkipUnchangedFiles="true"/>
        <Message Importance="normal" Text="2dog.gdextension: Copied Windows x64 $(TwoDogGdextWinX64PreferredVariant) native library to $(OutputPath)"/>
    </Target>

    <Target Name="TwoDogGdextWinX64PublishNatives"
            AfterTargets="Publish"
            Condition="'$(DesignTimeBuild)' != 'true' And (('$(RuntimeIdentifier)' == '' And $([MSBuild]::IsOSPlatform('Windows'))) Or $([System.String]::Copy('$(RuntimeIdentifier)').StartsWith('win'))) And '$(TwoDogGdextWinX64NativeLib)' != '' And Exists('$(TwoDogGdextWinX64NativeLib)')">
        <Copy SourceFiles="$(TwoDogGdextWinX64NativeLib)"
              DestinationFiles="$(PublishDir)libgodot-gdext-$(TwoDogGdextWinX64PreferredVariant).dll"
              SkipUnchangedFiles="true"/>
        <Message Importance="high" Text="2dog.gdextension: Published Windows x64 $(TwoDogGdextWinX64PreferredVariant) native library to $(PublishDir)"/>
    </Target>
</Project>
