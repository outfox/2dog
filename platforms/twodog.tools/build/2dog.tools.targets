<Project>
    <!--
      Exports the location of the GodotSharp editor tooling assemblies
      (GodotTools) shipped in this package. Consumed by the 2dog package's
      automatic import target (TwoDogImportGodotProject), which passes it to
      the import helper as GODOT_TOOLS_DIR.
    -->
    <PropertyGroup>
        <TwoDogGodotToolsDir Condition="'$(TwoDogGodotToolsDir)' == '' And Exists('$(MSBuildThisFileDirectory)../tools/GodotSharp/Tools/GodotTools.dll')">$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)../tools/GodotSharp/Tools/'))</TwoDogGodotToolsDir>
    </PropertyGroup>
</Project>
