<Project>
    <!--
      TwoDog Browser (wasm) Meta Package Targets

      Statically links the Godot engine (libgodot.a) into the consumer's
      `dotnet publish -r browser-wasm` via the wasm-tools workload, deploys the
      Godot web boot shell next to the app bundle, and exports the game
      project's content as a .pck during publish (running the export on the
      HOST desktop via the 2dog import helper).

      Everything is inert unless RuntimeIdentifier == browser-wasm.

      Requirements in the consuming (host) project:
        - net10.0+ TargetFramework, OutputType Exe, wasm-tools workload
        - PackageReference 2dog (brings twodog + GodotSharp + desktop editor
          packages used for import/export at build time)
        - <GodotProjectDir> pointing at the Godot project
        - a wwwroot/index.html boot page (see the 2dog web template)
        - the game project compiled with LIBGODOT_ENABLED + AllowUnsafeBlocks
          and its plugins initializer registered before Engine.Start()

      Configurable properties:
        TwoDogWebVariant:       'release' (default) or 'debug' (needs the
                                2dog.browser-wasm.debug package referenced)
        TwoDogWebNativeDir:     override the payload location entirely
        TwoDogExportPack:       'false' disables the automatic pck export
        TwoDogWebExportPreset:  export preset name (default 'Web')
        TwoDogWebPackName:      deployed pck file name (default 'godot.pck')
    -->

    <!-- Discover package version from this .targets location -->
    <PropertyGroup>
        <_TwoDogWebTargetsDir>$(MSBuildThisFileDirectory.TrimEnd('\').TrimEnd('/'))</_TwoDogWebTargetsDir>
        <TwoDogWebPackageVersion Condition="'$(TwoDogWebPackageVersion)' == ''">$([System.IO.Path]::GetFileName($([System.IO.Path]::GetDirectoryName('$(_TwoDogWebTargetsDir)'))))</TwoDogWebPackageVersion>
    </PropertyGroup>

    <!-- Variant selection: Debug configuration prefers the debug payload when
         its package is restored; everything else uses release. -->
    <PropertyGroup>
        <_TwoDogWebDebugPackageDir>$(NuGetPackageRoot)/2dog.browser-wasm.debug/$(TwoDogWebPackageVersion)/godot-web/</_TwoDogWebDebugPackageDir>
        <_TwoDogWebReleasePackageDir>$(NuGetPackageRoot)/2dog.browser-wasm.release/$(TwoDogWebPackageVersion)/godot-web/</_TwoDogWebReleasePackageDir>

        <TwoDogWebVariant Condition="'$(TwoDogWebVariant)' == '' And '$(Configuration)' == 'Debug' And Exists('$(_TwoDogWebDebugPackageDir)libgodot/libgodot.a')">debug</TwoDogWebVariant>
        <TwoDogWebVariant Condition="'$(TwoDogWebVariant)' == ''">release</TwoDogWebVariant>

        <_TwoDogWebBuildVariant Condition="'$(TwoDogWebVariant)' == 'debug'">template_debug</_TwoDogWebBuildVariant>
        <_TwoDogWebBuildVariant Condition="'$(_TwoDogWebBuildVariant)' == ''">template_release</_TwoDogWebBuildVariant>

        <!-- Resolve payload dir: NuGet package first, source checkout fallback -->
        <TwoDogWebNativeDir Condition="'$(TwoDogWebNativeDir)' == '' And '$(TwoDogWebVariant)' == 'debug' And Exists('$(_TwoDogWebDebugPackageDir)libgodot/libgodot.a')">$(_TwoDogWebDebugPackageDir)</TwoDogWebNativeDir>
        <TwoDogWebNativeDir Condition="'$(TwoDogWebNativeDir)' == '' And Exists('$(_TwoDogWebReleasePackageDir)libgodot/libgodot.a')">$(_TwoDogWebReleasePackageDir)</TwoDogWebNativeDir>
        <TwoDogWebNativeDir Condition="'$(TwoDogWebNativeDir)' == '' And Exists('$(MSBuildThisFileDirectory)../../../godot/bin/web/$(_TwoDogWebBuildVariant)/libgodot/libgodot.a')">$(MSBuildThisFileDirectory)../../../godot/bin/web/$(_TwoDogWebBuildVariant)/</TwoDogWebNativeDir>
    </PropertyGroup>

    <!-- Wasm build configuration -->
    <PropertyGroup Condition="'$(RuntimeIdentifier)' == 'browser-wasm'">
        <WasmBuildNative>true</WasmBuildNative>
        <!-- Fixed path: PublishDir is empty at static evaluation time, which
             would silently split the bundle and the post-publish steps. -->
        <WasmAppDir Condition="'$(WasmAppDir)' == ''">$(MSBuildProjectDirectory)/AppBundle</WasmAppDir>

        <WasmEnableSIMD Condition="'$(WasmEnableSIMD)' == ''">true</WasmEnableSIMD>
        <WasmInitialHeapSize Condition="'$(WasmInitialHeapSize)' == ''">32MB</WasmInitialHeapSize>
        <EmccStackSize Condition="'$(EmccStackSize)' == ''">5120KB</EmccStackSize>

        <PublishTrimmed Condition="'$(PublishTrimmed)' == ''">true</PublishTrimmed>
        <!-- partial: only assemblies that declare trim-compatibility
             (<IsTrimmable>true</IsTrimmable> - the BCL, twodog, the game
             project) are member-trimmed; GodotSharp is not trim-annotated
             upstream (see its csproj) and is preserved whole.
             TrimmerSingleWarn stays at the SDK default (true): GodotSharp's
             unannotated reflection internals produce trim-analysis warnings
             that roll up into a single IL2104 line per publish - that one
             line is the truthful status until GodotSharp is annotated
             upstream. Set TrimmerSingleWarn=false to see the full detail
             (useful when diagnosing trimming of your own assemblies). -->
        <TrimMode Condition="'$(TrimMode)' == ''">partial</TrimMode>

        <!-- No GodotPlugins.dll on web: plugin init flows through the game's
             registered function pointer (see twodog.Engine.RegisterWebPluginsInitializer). -->
        <TwoDogSkipGodotApiCopy>true</TwoDogSkipGodotApiCopy>

        <TwoDogExportPack Condition="'$(TwoDogExportPack)' == ''">true</TwoDogExportPack>
        <TwoDogWebExportPreset Condition="'$(TwoDogWebExportPreset)' == ''">Web</TwoDogWebExportPreset>
        <!-- The Godot engine JS derives all file names from the 'executable'
             config value; the default shell uses 'godot'. -->
        <TwoDogWebPackName Condition="'$(TwoDogWebPackName)' == ''">godot.pck</TwoDogWebPackName>
    </PropertyGroup>

    <ItemGroup Condition="'$(RuntimeIdentifier)' == 'browser-wasm'">
        <!-- Statically link Godot: every [LibraryImport("libgodot")] becomes a
             direct call into the archive. -->
        <DirectPInvoke Include="libgodot"/>
        <NativeLibrary Include="$(TwoDogWebNativeDir)libgodot/libgodot.a"/>

        <!-- GodotSharp is reached via reflection from scripts; twodog carries
             the WebTrampolines signature declarations the wasm build scans. -->
        <TrimmerRootAssembly Include="GodotSharp"/>
        <TrimmerRootAssembly Include="twodog"/>

        <!-- Some scenarios need marshal-ilgen while runtime marshalling is
             not disabled (see dotnet/android#7276; applies to wasm too). -->
        <_MonoComponent Include="marshal-ilgen"/>

        <EmccExportedFunction Include="_malloc;_free"/>
        <EmccExportedRuntimeMethod Include="callMain;cwrap;HEAP8;HEAPU8;HEAP16;HEAPU16;HEAP32;HEAPU32;HEAP64;HEAPU64;HEAPF32;HEAPF64"/>

        <_TwoDogGodotJsLibraries Include="$(TwoDogWebNativeDir)libgodot/js_library/**/*.js"/>
        <_TwoDogGodotPreJs Include="$(TwoDogWebNativeDir)libgodot/pre_js/**/*.js"/>
        <_TwoDogGodotPostJs Include="$(TwoDogWebNativeDir)libgodot/post_js/**/*.js"/>

        <!-- Godot-required emcc link flags (mirrors the engine's own web link;
             recorded in $(TwoDogWebNativeDir)libgodot/config.json). -->
        <TwoDogGodotEmccExtraLDFlag Include="-sMAX_WEBGL_VERSION=2"/>
        <TwoDogGodotEmccExtraLDFlag Include="-sOFFSCREEN_FRAMEBUFFER=1"/>
        <TwoDogGodotEmccExtraLDFlag Include="-sGL_ENABLE_GET_PROC_ADDRESS=0"/>
        <TwoDogGodotEmccExtraLDFlag Include="-sWASM_BIGINT"/>
        <TwoDogGodotEmccExtraLDFlag Include="-sMEMORY64=0"/>
        <TwoDogGodotEmccExtraLDFlag Include="-sENVIRONMENT=web,worker"/>
        <TwoDogGodotEmccExtraLDFlag Include="-sALLOW_MEMORY_GROWTH=1"/>
        <TwoDogGodotEmccExtraLDFlag Include="-sINVOKE_RUN=0"/>
        <TwoDogGodotEmccExtraLDFlag Include="-sEXIT_RUNTIME=1"/>
        <TwoDogGodotEmccExtraLDFlag Include="-sGL_WORKAROUND_SAFARI_GETCONTEXT_BUG=0"/>
        <TwoDogGodotEmccExtraLDFlag Include="-sTEXTDECODER=1"/>
        <TwoDogGodotEmccExtraLDFlag Include="-lidbfs.js"/>
        <TwoDogGodotEmccExtraLDFlag Include="@(_TwoDogGodotJsLibraries->'--js-library &quot;%(FullPath)&quot;'->Replace('\', '/'))"/>
        <TwoDogGodotEmccExtraLDFlag Include="@(_TwoDogGodotPreJs->'--pre-js &quot;%(FullPath)&quot;'->Replace('\', '/'))"/>
        <TwoDogGodotEmccExtraLDFlag Include="@(_TwoDogGodotPostJs->'--post-js &quot;%(FullPath)&quot;'->Replace('\', '/'))"/>

        <!-- Deploy the Godot boot shell and the consumer's static page. -->
        <WasmExtraFilesToDeploy Include="$(TwoDogWebNativeDir)shell/godot.js"/>
        <WasmExtraFilesToDeploy Include="$(TwoDogWebNativeDir)shell/godot.audio.worklet.js"/>
        <WasmExtraFilesToDeploy Include="$(TwoDogWebNativeDir)shell/godot.audio.position.worklet.js"/>
        <WasmExtraFilesToDeploy Include="$(MSBuildProjectDirectory)/wwwroot/**" Condition="Exists('$(MSBuildProjectDirectory)/wwwroot')"/>
    </ItemGroup>

    <PropertyGroup Condition="'$(RuntimeIdentifier)' == 'browser-wasm'">
        <EmccExtraLDFlags>$(EmccExtraLDFlags) @(TwoDogGodotEmccExtraLDFlag->'%(Identity)', ' ')</EmccExtraLDFlags>
    </PropertyGroup>

    <Target Name="TwoDogWebCheckNativeDir"
            BeforeTargets="Build"
            Condition="'$(RuntimeIdentifier)' == 'browser-wasm' And '$(DesignTimeBuild)' != 'true'">
        <Error Condition="'$(TwoDogWebNativeDir)' == '' Or !Exists('$(TwoDogWebNativeDir)libgodot/libgodot.a')"
               Text="TwoDog: web payload (libgodot.a) not found. Searched the 2dog.browser-wasm.$(TwoDogWebVariant) package v$(TwoDogWebPackageVersion) and the source checkout (godot/bin/web/$(_TwoDogWebBuildVariant)/). Restore the 2dog.browser-wasm package or build the web natives."/>
    </Target>

    <!-- The Godot engine JS expects the wasm at <executable>.wasm; the engine
         preloader fetches it and hands it to dotnet.js (mono_bridge), so it
         must live outside _framework under the executable name. Also prunes
         the stray copy of the static archive the wasm SDK deploys as a native
         asset. Hooks after bundle generation (an AfterTargets="Publish" hook
         runs before the nested wasm publish has generated the bundle). -->
    <Target Name="TwoDogWebFinalizeBundle"
            AfterTargets="_WasmGenerateAppBundle"
            Condition="'$(RuntimeIdentifier)' == 'browser-wasm'">
        <Move SourceFiles="$(WasmAppDir)/_framework/dotnet.native.wasm"
              DestinationFiles="$(WasmAppDir)/godot.wasm"
              Condition="Exists('$(WasmAppDir)/_framework/dotnet.native.wasm')"/>
        <Delete Files="$(WasmAppDir)/_framework/libgodot.wasm"/>
        <Message Importance="high" Text="TwoDog: web app bundle finalized at $(WasmAppDir)"/>
    </Target>

    <!-- ============================================ -->
    <!-- Content pipeline: export the game .pck        -->
    <!-- ============================================ -->
    <!-- Runs on the HOST desktop during publish, using the same capability
         plumbing as the 2dog package's automatic import target
         (TwoDogImportGodotProject in 2dog.targets): the in-process helper
         against the desktop editor-variant libgodot, or an explicitly
         configured external editor. Incremental over the game project
         sources. -->
    <PropertyGroup Condition="'$(RuntimeIdentifier)' == 'browser-wasm'">
        <!-- BaseIntermediateOutputPath (not IntermediateOutputPath): defined
             early by Microsoft.Common.props, so the path is stable whether
             these targets are imported from the package (after common
             targets) or from a source-checkout project body (before). -->
        <_TwoDogWebPackPath>$(BaseIntermediateOutputPath)twodog-web/$(TwoDogWebPackName)</_TwoDogWebPackPath>
    </PropertyGroup>

    <!-- Export incrementality inputs: the export must NOT borrow
         @(TwoDogImportInputs) - that item is only populated when
         TwoDogAutoImport is enabled, and an incremental target with empty
         Inputs is silently skipped, shipping a bundle without the pck.

         Directories carrying a .gdignore are skipped by the Godot export
         (and hold this very host's own build outputs when the web host is
         nested inside the Godot project - including the exported pck itself,
         which must never count as an input). -->
    <ItemGroup Condition="'$(RuntimeIdentifier)' == 'browser-wasm' And '$(TwoDogExportPack)' == 'true' And '$(TwoDogGodotProjectFullPath)' != ''">
        <_TwoDogWebGdIgnoredDirs Include="$(TwoDogGodotProjectFullPath)/**/.gdignore"/>
        <TwoDogWebExportInputs Include="$(TwoDogGodotProjectFullPath)/**/*"
                               Exclude="$(TwoDogGodotProjectFullPath)/.godot/**;$(TwoDogGodotProjectFullPath)/bin/**;$(TwoDogGodotProjectFullPath)/obj/**;$(TwoDogGodotProjectFullPath)/**/*.tmp;$(TwoDogGodotProjectFullPath)/**/.DS_Store;@(_TwoDogWebGdIgnoredDirs->'%(RootDir)%(Directory)**');$(TwoDogImportExcludes)"/>
    </ItemGroup>

    <Target Name="TwoDogExportGamePack"
            BeforeTargets="Publish"
            AfterTargets="Build"
            Inputs="@(TwoDogWebExportInputs)"
            Outputs="$(_TwoDogWebPackPath)"
            Condition="'$(RuntimeIdentifier)' == 'browser-wasm' And '$(DesignTimeBuild)' != 'true' And '$(TwoDogExportPack)' == 'true' And '$(TwoDogGodotProjectFullPath)' != '' And Exists('$(TwoDogGodotProjectFullPath)/project.godot')">

        <PropertyGroup>
            <_TwoDogExportEditor>$(GodotEditor)</_TwoDogExportEditor>
            <_TwoDogExportEditor Condition="'$(_TwoDogExportEditor)' == ''">$(GODOT_EDITOR)</_TwoDogExportEditor>
            <_TwoDogToolsDir>$(TwoDogGodotToolsDir)</_TwoDogToolsDir>
            <_TwoDogToolsDir Condition="'$(_TwoDogToolsDir)' == '' And Exists('$(MSBuildThisFileDirectory)../../../godot/bin/GodotSharp/Tools/GodotTools.dll')">$(MSBuildThisFileDirectory)../../../godot/bin/GodotSharp/Tools/</_TwoDogToolsDir>
            <_TwoDogCanUseHelper>false</_TwoDogCanUseHelper>
            <_TwoDogCanUseHelper Condition="'$(TwoDogImportHelperPath)' != '' And '$(TwoDogEditorLibGodotPath)' != '' And Exists('$(TwoDogEditorLibGodotPath)') And '$(_TwoDogToolsDir)' != '' And '$(TwoDogGodotApiSourcePath)' != ''">true</_TwoDogCanUseHelper>
            <_TwoDogToolsDirArg>$(_TwoDogToolsDir.TrimEnd('\').TrimEnd('/'))</_TwoDogToolsDirArg>
            <_TwoDogApiDirArg>$(TwoDogGodotApiSourcePath.TrimEnd('\').TrimEnd('/'))</_TwoDogApiDirArg>
            <_TwoDogWebPackFullPath>$([System.IO.Path]::GetFullPath($([System.IO.Path]::Combine('$(MSBuildProjectDirectory)', '$(_TwoDogWebPackPath)'))))</_TwoDogWebPackFullPath>
        </PropertyGroup>

        <MakeDir Directories="$([System.IO.Path]::GetDirectoryName('$(_TwoDogWebPackFullPath)'))"/>

        <!-- (1) explicitly configured external editor -->
        <Exec Condition="'$(_TwoDogExportEditor)' != ''"
              Command="&quot;$(_TwoDogExportEditor)&quot; --headless --export-pack &quot;$(TwoDogWebExportPreset)&quot; &quot;$(_TwoDogWebPackFullPath)&quot; --path &quot;$(TwoDogGodotProjectFullPath)&quot;"
              IgnoreStandardErrorWarningFormat="true"/>

        <!-- (2) in-process export helper against the packaged editor libgodot -->
        <Exec Condition="'$(_TwoDogExportEditor)' == '' And '$(_TwoDogCanUseHelper)' == 'true'"
              Command="&quot;$(_TwoDogDotNetHost)&quot; exec &quot;$(TwoDogImportHelperPath)&quot; --export-pack &quot;$(TwoDogWebExportPreset)&quot; --output &quot;$(_TwoDogWebPackFullPath)&quot; --libgodot &quot;$(TwoDogEditorLibGodotPath)&quot; --api-dir &quot;$(_TwoDogApiDirArg)&quot; --tools-dir &quot;$(_TwoDogToolsDirArg)&quot; &quot;$(TwoDogGodotProjectFullPath)&quot;"
              EnvironmentVariables="GODOTSHARP_DIR=$(_TwoDogApiDirArg);GODOT_TOOLS_DIR=$(_TwoDogToolsDirArg)"
              IgnoreStandardErrorWarningFormat="true"/>

        <Error Condition="'$(_TwoDogExportEditor)' == '' And '$(_TwoDogCanUseHelper)' != 'true'"
               Text="TwoDog: web publish needs to export '$(TwoDogGodotProjectFullPath)' as a .pck, but no export capability was found (editor libgodot='$(TwoDogEditorLibGodotPath)', helper='$(TwoDogImportHelperPath)', tools='$(_TwoDogToolsDir)'). Set &lt;GodotEditor&gt; to a Godot editor binary, or restore the 2dog.&lt;host-rid&gt;.editor and 2dog.tools packages. Set &lt;TwoDogExportPack&gt;false&lt;/TwoDogExportPack&gt; to provide the pck yourself (wwwroot/$(TwoDogWebPackName))."/>
    </Target>

    <!-- Deploy the exported pck into the app bundle. Separate from the export
         so an up-to-date (skipped) export still deploys. -->
    <Target Name="TwoDogDeployPack"
            AfterTargets="TwoDogWebFinalizeBundle"
            Condition="'$(RuntimeIdentifier)' == 'browser-wasm' And '$(TwoDogExportPack)' == 'true' And Exists('$(_TwoDogWebPackPath)')">
        <Copy SourceFiles="$(_TwoDogWebPackPath)"
              DestinationFiles="$(WasmAppDir)/$(TwoDogWebPackName)"
              SkipUnchangedFiles="true"/>
        <Message Importance="high" Text="TwoDog: deployed $(TwoDogWebPackName) to the app bundle"/>
    </Target>
</Project>
