<Project>
    <!--
      TwoDog Linux x64 Meta Package Targets

      Parameter block for the shared native resolver
      (2dog.native-resolver.targets, shipped alongside this file): declares
      where this package's natives live and how they are named. The shared
      targets resolve the $(TwoDogVariant) native - NuGet package first,
      local godot/bin fallback - and copy it to output/publish as
      libgodot-<variant>.so.
    -->
    <PropertyGroup>
        <_TwoDogLinuxX64TargetsDir>$(MSBuildThisFileDirectory.TrimEnd('\').TrimEnd('/'))</_TwoDogLinuxX64TargetsDir>
        <TwoDogLinuxX64PackageVersion Condition="'$(TwoDogLinuxX64PackageVersion)' == ''">$([System.IO.Path]::GetFileName($([System.IO.Path]::GetDirectoryName('$(_TwoDogLinuxX64TargetsDir)'))))</TwoDogLinuxX64PackageVersion>
        <TwoDogLocalGodotBin Condition="'$(TwoDogLocalGodotBin)' == ''">$(MSBuildThisFileDirectory)../../../godot/bin/</TwoDogLocalGodotBin>
    </PropertyGroup>

    <!-- Export the editor libgodot location for the build machine. Consumed by
         the 2dog.engine package's automatic import target
         (TwoDogImportGodotProject), which runs the import helper against it.
         Host-OS guarded (not RID): the import runs on the machine doing the
         build. -->
    <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('Linux'))">
        <_TwoDogLinuxX64EditorPackage>$(NuGetPackageRoot)/2dog.linux-x64.editor/$(TwoDogLinuxX64PackageVersion)/runtimes/linux-x64/native/libgodot-editor.so</_TwoDogLinuxX64EditorPackage>
        <TwoDogEditorLibGodotPath Condition="'$(TwoDogEditorLibGodotPath)' == '' And Exists('$(_TwoDogLinuxX64EditorPackage)')">$(_TwoDogLinuxX64EditorPackage)</TwoDogEditorLibGodotPath>
        <TwoDogEditorLibGodotPath Condition="'$(TwoDogEditorLibGodotPath)' == '' And Exists('$(TwoDogLocalGodotBin)libgodot.linuxbsd.editor.x86_64.shared_library.so')">$(TwoDogLocalGodotBin)libgodot.linuxbsd.editor.x86_64.shared_library.so</TwoDogEditorLibGodotPath>
    </PropertyGroup>

    <ItemGroup>
        <TwoDogNativeResolver Include="linux-x64">
            <PackageId>2dog.linux-x64</PackageId>
            <PackageVersion>$(TwoDogLinuxX64PackageVersion)</PackageVersion>
            <LibPrefix>libgodot</LibPrefix>
            <Ext>so</Ext>
            <HostOs>Linux</HostOs>
            <RidPrefix>linux</RidPrefix>
            <LocalBin>$(TwoDogLocalGodotBin)</LocalBin>
            <LocalRelease>libgodot.linuxbsd.template_release.x86_64.shared_library.so</LocalRelease>
            <LocalDebug>libgodot.linuxbsd.template_debug.x86_64.shared_library.so</LocalDebug>
            <LocalEditor>libgodot.linuxbsd.editor.x86_64.shared_library.so</LocalEditor>
        </TwoDogNativeResolver>
    </ItemGroup>

    <Import Project="$(MSBuildThisFileDirectory)2dog.native-resolver.targets"
            Condition="'$(_TwoDogNativeResolverImported)' != 'true' And Exists('$(MSBuildThisFileDirectory)2dog.native-resolver.targets')"/>
    <Import Project="$(MSBuildThisFileDirectory)../../common/2dog.native-resolver.targets"
            Condition="'$(_TwoDogNativeResolverImported)' != 'true'"/>
</Project>
