<Project>
    <!--
      TwoDog Windows x64 Meta Package Targets

      Parameter block for the shared native resolver
      (2dog.native-resolver.targets, shipped alongside this file): declares
      where this package's natives live and how they are named. The shared
      targets resolve the $(TwoDogVariant) native - NuGet package first,
      local godot/bin fallback - and copy it to output/publish as
      libgodot-<variant>.dll.
    -->
    <PropertyGroup>
        <_TwoDogWinX64TargetsDir>$(MSBuildThisFileDirectory.TrimEnd('\').TrimEnd('/'))</_TwoDogWinX64TargetsDir>
        <TwoDogWinX64PackageVersion Condition="'$(TwoDogWinX64PackageVersion)' == ''">$([System.IO.Path]::GetFileName($([System.IO.Path]::GetDirectoryName('$(_TwoDogWinX64TargetsDir)'))))</TwoDogWinX64PackageVersion>
        <TwoDogLocalGodotBin Condition="'$(TwoDogLocalGodotBin)' == ''">$(MSBuildThisFileDirectory)../../../godot/bin/</TwoDogLocalGodotBin>
    </PropertyGroup>

    <!-- Export the editor libgodot location for the build machine. Consumed by
         the 2dog.engine package's automatic import target
         (TwoDogImportGodotProject), which runs the import helper against it.
         Host-OS guarded (not RID): the import runs on the machine doing the
         build. -->
    <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('Windows'))">
        <_TwoDogWinX64EditorPackage>$(NuGetPackageRoot)/2dog.win-x64.editor/$(TwoDogWinX64PackageVersion)/runtimes/win-x64/native/libgodot-editor.dll</_TwoDogWinX64EditorPackage>
        <TwoDogEditorLibGodotPath Condition="'$(TwoDogEditorLibGodotPath)' == '' And Exists('$(_TwoDogWinX64EditorPackage)')">$(_TwoDogWinX64EditorPackage)</TwoDogEditorLibGodotPath>
        <TwoDogEditorLibGodotPath Condition="'$(TwoDogEditorLibGodotPath)' == '' And Exists('$(TwoDogLocalGodotBin)godot.windows.editor.x86_64.shared_library.dll')">$(TwoDogLocalGodotBin)godot.windows.editor.x86_64.shared_library.dll</TwoDogEditorLibGodotPath>
    </PropertyGroup>

    <ItemGroup>
        <TwoDogNativeResolver Include="win-x64">
            <PackageId>2dog.win-x64</PackageId>
            <PackageVersion>$(TwoDogWinX64PackageVersion)</PackageVersion>
            <LibPrefix>libgodot</LibPrefix>
            <Ext>dll</Ext>
            <HostOs>Windows</HostOs>
            <RidPrefix>win</RidPrefix>
            <LocalBin>$(TwoDogLocalGodotBin)</LocalBin>
            <LocalRelease>godot.windows.template_release.x86_64.shared_library.dll</LocalRelease>
            <LocalDebug>godot.windows.template_debug.x86_64.shared_library.dll</LocalDebug>
            <LocalEditor>godot.windows.editor.x86_64.shared_library.dll</LocalEditor>
        </TwoDogNativeResolver>
    </ItemGroup>

    <Import Project="$(MSBuildThisFileDirectory)2dog.native-resolver.targets"
            Condition="'$(_TwoDogNativeResolverImported)' != 'true' And Exists('$(MSBuildThisFileDirectory)2dog.native-resolver.targets')"/>
    <Import Project="$(MSBuildThisFileDirectory)../../common/2dog.native-resolver.targets"
            Condition="'$(_TwoDogNativeResolverImported)' != 'true'"/>
</Project>
