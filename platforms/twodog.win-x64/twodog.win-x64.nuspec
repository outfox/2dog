<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
    <metadata>
        <id>2dog.win-x64</id>
        <version>$version$</version>
        <authors>$authors$</authors>
        <license type="expression">MIT</license>
        <icon>icon.png</icon>
        <readme>README.md</readme>
        <projectUrl>https://github.com/outfox/2dog</projectUrl>
        <description>$description$</description>
        <dependencies>
            <group targetFramework=".NETStandard2.0">
                <!-- exclude="native": the runtimes/<rid>/native assets must not
                     flow to consumers (all three variants would be copied into
                     every output dir); the meta targets copy the one selected
                     by $(TwoDogVariant) from the package cache instead. -->
                <dependency id="2dog.win-x64.release" version="[$version$]" exclude="native"/>
                <dependency id="2dog.win-x64.debug" version="[$version$]" exclude="native"/>
                <dependency id="2dog.win-x64.editor" version="[$version$]" exclude="native"/>
            </group>
        </dependencies>
    </metadata>
    <files>
        <file src="../../nuget/icon.png" target="icon.png"/>
        <file src="README.md" target="README.md"/>
        <file src="../../nuget/GODOT_LICENSE.txt" target="LICENSE.txt"/>
        <file src="../../nuget/GODOT_AUTHORS.md" target="AUTHORS.md"/>
        <!-- MSBuild targets for native library copying -->
        <file src="build/2dog.win-x64.targets" target="build/2dog.win-x64.targets"/>
        <file src="../common/2dog.native-resolver.targets" target="build/2dog.native-resolver.targets"/>
        <file src="buildTransitive/2dog.win-x64.targets" target="buildTransitive/2dog.win-x64.targets"/>
    </files>
</package>
