<Project>
    <!--
      2dog.gdextension Linux x64 Meta Package Targets

      Parameter block for the shared native resolver
      (2dog.native-resolver.targets, shipped alongside this file): declares
      where this package's non-mono natives live and how they are named. The
      shared targets resolve the $(TwoDogVariant) native - NuGet package
      first, local godot/bin fallback (extra_suffix=gdext_shared_library) -
      and copy it to output/publish as libgodot-gdext-<variant>.so.
    -->
    <PropertyGroup>
        <_TwoDogGdextLinuxX64TargetsDir>$(MSBuildThisFileDirectory.TrimEnd('\').TrimEnd('/'))</_TwoDogGdextLinuxX64TargetsDir>
        <TwoDogGdextLinuxX64PackageVersion Condition="'$(TwoDogGdextLinuxX64PackageVersion)' == ''">$([System.IO.Path]::GetFileName($([System.IO.Path]::GetDirectoryName('$(_TwoDogGdextLinuxX64TargetsDir)'))))</TwoDogGdextLinuxX64PackageVersion>
        <TwoDogLocalGodotBin Condition="'$(TwoDogLocalGodotBin)' == ''">$(MSBuildThisFileDirectory)../../../godot/bin/</TwoDogLocalGodotBin>
    </PropertyGroup>

    <ItemGroup>
        <TwoDogNativeResolver Include="linux-x64">
            <PackageId>2dog.gdextension.linux-x64</PackageId>
            <PackageVersion>$(TwoDogGdextLinuxX64PackageVersion)</PackageVersion>
            <LibPrefix>libgodot-gdext</LibPrefix>
            <Ext>so</Ext>
            <HostOs>Linux</HostOs>
            <RidPrefix>linux</RidPrefix>
            <LocalBin>$(TwoDogLocalGodotBin)</LocalBin>
            <LocalRelease>libgodot.linuxbsd.template_release.x86_64.gdext_shared_library.so</LocalRelease>
            <LocalDebug>libgodot.linuxbsd.template_debug.x86_64.gdext_shared_library.so</LocalDebug>
            <LocalEditor>libgodot.linuxbsd.editor.x86_64.gdext_shared_library.so</LocalEditor>
        </TwoDogNativeResolver>
    </ItemGroup>

    <Import Project="$(MSBuildThisFileDirectory)2dog.native-resolver.targets"
            Condition="'$(_TwoDogNativeResolverImported)' != 'true' And Exists('$(MSBuildThisFileDirectory)2dog.native-resolver.targets')"/>
    <Import Project="$(MSBuildThisFileDirectory)../../common/2dog.native-resolver.targets"
            Condition="'$(_TwoDogNativeResolverImported)' != 'true'"/>
</Project>
