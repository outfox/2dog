<Project Sdk="Microsoft.NET.Sdk">
    <!-- Platform-specific configuration (GDExtension flavor: non-mono natives) -->
    <PropertyGroup>
        <GdExtension>true</GdExtension>
        <PlatformRID>linux-x64</PlatformRID>
        <PlatformOS>linuxbsd</PlatformOS>
        <BuildVariant>template_debug</BuildVariant>
        <NativeLibExt>so</NativeLibExt>
        <PackageSuffix>.debug</PackageSuffix>
        <Description>Linux x64 debug native libgodot-gdext library for 2dog.gdextension. Reference this package alongside 2dog.gdextension for Linux debug support.</Description>
    </PropertyGroup>
</Project>
