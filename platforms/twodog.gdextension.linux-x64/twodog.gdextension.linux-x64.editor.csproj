<Project Sdk="Microsoft.NET.Sdk">
    <!-- Platform-specific configuration (GDExtension flavor: non-mono natives) -->
    <PropertyGroup>
        <GdExtension>true</GdExtension>
        <PlatformRID>linux-x64</PlatformRID>
        <PlatformOS>linuxbsd</PlatformOS>
        <BuildVariant>editor</BuildVariant>
        <NativeLibExt>so</NativeLibExt>
        <PackageSuffix>.editor</PackageSuffix>
        <Description>Linux x64 editor native libgodot-gdext library for 2dog.gdextension. Reference this package alongside 2dog.gdextension for Linux editor support.</Description>
    </PropertyGroup>
</Project>
