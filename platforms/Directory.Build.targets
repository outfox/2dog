<Project>
    <!-- Computed properties that depend on platform-specific inputs from individual csproj files -->
    <!-- Skip for meta packages that already define their own PackageId -->
    <PropertyGroup Condition="'$(PlatformRID)' != '' And '$(PlatformOS)' != 'web'">
        <!-- Package ID: 2dog.<rid>[.suffix] -->
        <PackageId>2dog.$(PlatformRID)$(PackageSuffix)</PackageId>

        <!-- Native library source path -->
        <NativeLibPrefix Condition="'$(PlatformOS)' == 'windows'">godot</NativeLibPrefix>
        <NativeLibPrefix Condition="'$(PlatformOS)' != 'windows'">libgodot</NativeLibPrefix>
        <PlatformArch Condition="'$(PlatformArch)' == ''">x86_64</PlatformArch>
        <NativeLibPath>$(GodotBinDir)$(NativeLibPrefix).$(PlatformOS).$(BuildVariant).$(PlatformArch).shared_library.$(NativeLibExt)</NativeLibPath>

        <!-- Output library name: libgodot-<variant>.<ext>. The variant suffix
             makes each native uniquely named so all three variants can coexist
             in one project and a variant mismatch fails loudly at load time
             (twodog's DllImportResolver picks the file by TwoDogVariant). -->
        <VariantShortName Condition="'$(BuildVariant)' == 'template_release'">release</VariantShortName>
        <VariantShortName Condition="'$(BuildVariant)' == 'template_debug'">debug</VariantShortName>
        <VariantShortName Condition="'$(BuildVariant)' == 'editor'">editor</VariantShortName>
        <OutputLibName>libgodot-$(VariantShortName).$(NativeLibExt)</OutputLibName>

        <!-- Skip packaging if native library doesn't exist (unless forcing all platforms) -->
        <IsPackable Condition="'$(ForcePackAllPlatforms)' != 'true' And !Exists('$(NativeLibPath)')">false</IsPackable>
    </PropertyGroup>

    <!-- Web (browser-wasm) variants pack a whole payload directory instead of a
         single shared library: the emscripten static archive plus the JS glue
         and boot shell it must be linked/served with. The runtimes/<rid>/native
         convention buys nothing here (the .a is consumed by an explicit
         NativeLibrary item at publish time, never by the runtime host), so the
         payload lives under a dedicated godot-web/ folder. -->
    <PropertyGroup Condition="'$(PlatformRID)' != '' And '$(PlatformOS)' == 'web'">
        <PackageId>2dog.$(PlatformRID)$(PackageSuffix)</PackageId>
        <WebPayloadDir>$(GodotBinDir)web/$(BuildVariant)/</WebPayloadDir>
        <IsPackable Condition="'$(ForcePackAllPlatforms)' != 'true' And !Exists('$(WebPayloadDir)libgodot/libgodot.a')">false</IsPackable>
    </PropertyGroup>

    <ItemGroup Condition="'$(PlatformRID)' != '' And '$(PlatformOS)' == 'web'">
        <None Include="$(WebPayloadDir)**"
              Pack="true"
              PackagePath="godot-web/"
              Visible="false"/>
    </ItemGroup>

    <!-- Meta packages don't have native libraries, so close the conditional PropertyGroup above -->
    <PropertyGroup Condition="'$(PlatformRID)' == ''">
        <!-- Meta packages define their own PackageId and IsPackable -->
    </PropertyGroup>

    <!-- Include native library in the package using NuGet runtimes convention -->
    <ItemGroup>
        <None Include="$(NativeLibPath)"
              Condition="Exists('$(NativeLibPath)')"
              Pack="true"
              PackagePath="runtimes/$(PlatformRID)/native/$(OutputLibName)"
              Visible="false"
              Link="runtimes/$(PlatformRID)/native/$(OutputLibName)"
              CopyToOutputDirectory="PreserveNewest"/>
    </ItemGroup>

    <!-- Include MSBuild targets in the package -->
    <!-- Only meta packages (no PackageSuffix) should include targets.
         Variant packages (.release, .debug, .editor) are DLL-only; meta packages own copy logic. -->
    <ItemGroup Condition="'$(PackageSuffix)' == ''">
        <None Include="build/$(PackageId).targets" Pack="true" PackagePath="build/" Condition="Exists('build/$(PackageId).targets')"/>
        <None Include="buildTransitive/$(PackageId).targets" Pack="true" PackagePath="buildTransitive/" Condition="Exists('buildTransitive/$(PackageId).targets')"/>
    </ItemGroup>

    <!-- Record the godot submodule commit these natives were built from in the
         package's repository metadata. The CI pack job reads it back from
         nuget.org to refuse republishing a NativesVersion whose binaries came
         from a different submodule commit (the deploy job's skip-duplicate push
         would otherwise silently keep the stale natives). Uses the committed pointer
         (HEAD:godot), matching how CI keys its native build cache. -->
    <Target Name="StampGodotSubmoduleCommit" BeforeTargets="GenerateNuspec">
        <Exec Command="git rev-parse HEAD:godot"
              WorkingDirectory="$(MSBuildThisFileDirectory)../"
              ConsoleToMSBuild="true"
              StandardOutputImportance="low">
            <Output TaskParameter="ConsoleOutput" PropertyName="GodotSubmoduleCommit"/>
        </Exec>
        <PropertyGroup>
            <RepositoryType>git</RepositoryType>
            <RepositoryUrl>https://github.com/thygrrr/godot</RepositoryUrl>
            <RepositoryCommit>$(GodotSubmoduleCommit.Trim())</RepositoryCommit>
        </PropertyGroup>
    </Target>

    <Target Name="TwoDogDeepClean" AfterTargets="Clean">
        <RemoveDir Directories="$(BaseIntermediateOutputPath)"/>
        <RemoveDir Directories="$(BaseOutputPath)"/>
    </Target>
</Project>
