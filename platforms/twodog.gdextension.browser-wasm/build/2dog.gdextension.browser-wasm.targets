<Project>
    <!--
      TwoDog GDExtension Browser (wasm) Meta Package Targets

      Statically links the non-mono Godot engine (libgodot.a) into the
      consumer's `dotnet publish -r browser-wasm` via the wasm-tools workload
      and deploys the Godot web boot shell next to the app bundle. The
      GDExtension host registers itself through the embedded-extension init
      callback - no GodotPlugins, no mono module.

      Everything is inert unless RuntimeIdentifier == browser-wasm.

      Requirements in the consuming (host) project:
        - net10.0+ TargetFramework, OutputType Exe, wasm-tools workload
        - PackageReference 2dog.gdextension (brings twodog.bindings)
        - a wwwroot/index.html boot page and (until the automatic export
          pipeline lands) a wwwroot/godot.pck with the game content

      Configurable properties:
        TwoDogWebVariant:   'release' (default) or 'debug' (needs the
                            2dog.gdextension.browser-wasm.debug package
                            referenced)
        TwoDogWebNativeDir: override the payload location entirely
    -->

    <!-- Discover package version from this .targets location -->
    <PropertyGroup>
        <_TwoDogGdextWebTargetsDir>$(MSBuildThisFileDirectory.TrimEnd('\').TrimEnd('/'))</_TwoDogGdextWebTargetsDir>
        <TwoDogWebPackageVersion Condition="'$(TwoDogWebPackageVersion)' == ''">$([System.IO.Path]::GetFileName($([System.IO.Path]::GetDirectoryName('$(_TwoDogGdextWebTargetsDir)'))))</TwoDogWebPackageVersion>
    </PropertyGroup>

    <!-- Variant selection: Debug configuration prefers the debug payload when
         its package is restored; everything else uses release. -->
    <PropertyGroup>
        <_TwoDogGdextWebDebugPackageDir>$(NuGetPackageRoot)/2dog.gdextension.browser-wasm.debug/$(TwoDogWebPackageVersion)/godot-web/</_TwoDogGdextWebDebugPackageDir>
        <_TwoDogGdextWebReleasePackageDir>$(NuGetPackageRoot)/2dog.gdextension.browser-wasm.release/$(TwoDogWebPackageVersion)/godot-web/</_TwoDogGdextWebReleasePackageDir>

        <TwoDogWebVariant Condition="'$(TwoDogWebVariant)' == '' And '$(Configuration)' == 'Debug' And Exists('$(_TwoDogGdextWebDebugPackageDir)libgodot/libgodot.a')">debug</TwoDogWebVariant>
        <TwoDogWebVariant Condition="'$(TwoDogWebVariant)' == ''">release</TwoDogWebVariant>

        <_TwoDogGdextWebBuildVariant Condition="'$(TwoDogWebVariant)' == 'debug'">template_debug</_TwoDogGdextWebBuildVariant>
        <_TwoDogGdextWebBuildVariant Condition="'$(_TwoDogGdextWebBuildVariant)' == ''">template_release</_TwoDogGdextWebBuildVariant>

        <!-- Resolve payload dir: NuGet package first, source checkout fallback -->
        <TwoDogWebNativeDir Condition="'$(TwoDogWebNativeDir)' == '' And '$(TwoDogWebVariant)' == 'debug' And Exists('$(_TwoDogGdextWebDebugPackageDir)libgodot/libgodot.a')">$(_TwoDogGdextWebDebugPackageDir)</TwoDogWebNativeDir>
        <TwoDogWebNativeDir Condition="'$(TwoDogWebNativeDir)' == '' And Exists('$(_TwoDogGdextWebReleasePackageDir)libgodot/libgodot.a')">$(_TwoDogGdextWebReleasePackageDir)</TwoDogWebNativeDir>
        <TwoDogWebNativeDir Condition="'$(TwoDogWebNativeDir)' == '' And Exists('$(MSBuildThisFileDirectory)../../../godot/bin/web-gdext/$(_TwoDogGdextWebBuildVariant)/libgodot/libgodot.a')">$(MSBuildThisFileDirectory)../../../godot/bin/web-gdext/$(_TwoDogGdextWebBuildVariant)/</TwoDogWebNativeDir>
    </PropertyGroup>

    <!-- Wasm build configuration -->
    <PropertyGroup Condition="'$(RuntimeIdentifier)' == 'browser-wasm'">
        <WasmBuildNative>true</WasmBuildNative>
        <!-- Fixed path: PublishDir is empty at static evaluation time, which
             would silently split the bundle and the post-publish steps. -->
        <WasmAppDir Condition="'$(WasmAppDir)' == ''">$(MSBuildProjectDirectory)/AppBundle</WasmAppDir>

        <WasmEnableSIMD Condition="'$(WasmEnableSIMD)' == ''">true</WasmEnableSIMD>
        <WasmInitialHeapSize Condition="'$(WasmInitialHeapSize)' == ''">32MB</WasmInitialHeapSize>
        <EmccStackSize Condition="'$(EmccStackSize)' == ''">5120KB</EmccStackSize>

        <PublishTrimmed Condition="'$(PublishTrimmed)' == ''">true</PublishTrimmed>
        <!-- partial: only assemblies that declare trim-compatibility are
             member-trimmed. The bindings stay rooted: the engine reaches
             registered extension classes and the ApiRegistry factories at
             runtime, not statically. -->
        <TrimMode Condition="'$(TrimMode)' == ''">partial</TrimMode>
    </PropertyGroup>

    <ItemGroup Condition="'$(RuntimeIdentifier)' == 'browser-wasm'">
        <!-- Statically link Godot: every [LibraryImport("libgodot")] becomes a
             direct call into the archive. -->
        <DirectPInvoke Include="libgodot"/>
        <NativeLibrary Include="$(TwoDogWebNativeDir)libgodot/libgodot.a"/>

        <TrimmerRootAssembly Include="twodog.bindings"/>
        <TrimmerRootAssembly Include="twodog.gdextension"/>

        <!-- Some scenarios need marshal-ilgen while runtime marshalling is
             not disabled (see dotnet/android#7276; applies to wasm too). -->
        <_MonoComponent Include="marshal-ilgen"/>

        <EmccExportedFunction Include="_malloc;_free"/>
        <EmccExportedRuntimeMethod Include="callMain;cwrap;HEAP8;HEAPU8;HEAP16;HEAPU16;HEAP32;HEAPU32;HEAP64;HEAPU64;HEAPF32;HEAPF64"/>

        <_TwoDogGodotJsLibraries Include="$(TwoDogWebNativeDir)libgodot/js_library/**/*.js"/>
        <_TwoDogGodotPreJs Include="$(TwoDogWebNativeDir)libgodot/pre_js/**/*.js"/>
        <_TwoDogGodotPostJs Include="$(TwoDogWebNativeDir)libgodot/post_js/**/*.js"/>

        <!-- Godot-required emcc link flags (mirrors the engine's own web link;
             recorded in $(TwoDogWebNativeDir)libgodot/config.json). -->
        <TwoDogGodotEmccExtraLDFlag Include="-sMAX_WEBGL_VERSION=2"/>
        <TwoDogGodotEmccExtraLDFlag Include="-sOFFSCREEN_FRAMEBUFFER=1"/>
        <TwoDogGodotEmccExtraLDFlag Include="-sGL_ENABLE_GET_PROC_ADDRESS=0"/>
        <TwoDogGodotEmccExtraLDFlag Include="-sWASM_BIGINT"/>
        <TwoDogGodotEmccExtraLDFlag Include="-sMEMORY64=0"/>
        <TwoDogGodotEmccExtraLDFlag Include="-sENVIRONMENT=web,worker"/>
        <TwoDogGodotEmccExtraLDFlag Include="-sALLOW_MEMORY_GROWTH=1"/>
        <TwoDogGodotEmccExtraLDFlag Include="-sINVOKE_RUN=0"/>
        <TwoDogGodotEmccExtraLDFlag Include="-sEXIT_RUNTIME=1"/>
        <TwoDogGodotEmccExtraLDFlag Include="-sGL_WORKAROUND_SAFARI_GETCONTEXT_BUG=0"/>
        <TwoDogGodotEmccExtraLDFlag Include="-sTEXTDECODER=1"/>
        <TwoDogGodotEmccExtraLDFlag Include="-lidbfs.js"/>
        <TwoDogGodotEmccExtraLDFlag Include="@(_TwoDogGodotJsLibraries->'--js-library &quot;%(FullPath)&quot;'->Replace('\', '/'))"/>
        <TwoDogGodotEmccExtraLDFlag Include="@(_TwoDogGodotPreJs->'--pre-js &quot;%(FullPath)&quot;'->Replace('\', '/'))"/>
        <TwoDogGodotEmccExtraLDFlag Include="@(_TwoDogGodotPostJs->'--post-js &quot;%(FullPath)&quot;'->Replace('\', '/'))"/>

        <!-- Deploy the Godot boot shell and the consumer's static page. -->
        <WasmExtraFilesToDeploy Include="$(TwoDogWebNativeDir)shell/godot.js"/>
        <WasmExtraFilesToDeploy Include="$(TwoDogWebNativeDir)shell/godot.audio.worklet.js"/>
        <WasmExtraFilesToDeploy Include="$(TwoDogWebNativeDir)shell/godot.audio.position.worklet.js"/>
        <WasmExtraFilesToDeploy Include="$(MSBuildProjectDirectory)/wwwroot/**" Condition="Exists('$(MSBuildProjectDirectory)/wwwroot')"/>
    </ItemGroup>

    <PropertyGroup Condition="'$(RuntimeIdentifier)' == 'browser-wasm'">
        <EmccExtraLDFlags>$(EmccExtraLDFlags) @(TwoDogGodotEmccExtraLDFlag->'%(Identity)', ' ')</EmccExtraLDFlags>
    </PropertyGroup>

    <Target Name="TwoDogGdextWebCheckNativeDir"
            BeforeTargets="Build"
            Condition="'$(RuntimeIdentifier)' == 'browser-wasm' And '$(DesignTimeBuild)' != 'true'">
        <Error Condition="'$(TwoDogWebNativeDir)' == '' Or !Exists('$(TwoDogWebNativeDir)libgodot/libgodot.a')"
               Text="TwoDog: gdext web payload (libgodot.a) not found. Searched the 2dog.gdextension.browser-wasm.$(TwoDogWebVariant) package v$(TwoDogWebPackageVersion) and the source checkout (godot/bin/web-gdext/$(_TwoDogGdextWebBuildVariant)/). Restore the 2dog.gdextension.browser-wasm package or build the web natives (build-godot.py --mono no --platform web)."/>
    </Target>

    <!-- The Godot engine JS expects the wasm at <executable>.wasm; the engine
         preloader fetches it and hands it to dotnet.js, so it must live
         outside _framework under the executable name. Also prunes the stray
         copy of the static archive the wasm SDK deploys as a native asset.
         Hooks after bundle generation (an AfterTargets="Publish" hook runs
         before the nested wasm publish has generated the bundle). -->
    <Target Name="TwoDogGdextWebFinalizeBundle"
            AfterTargets="_WasmGenerateAppBundle"
            Condition="'$(RuntimeIdentifier)' == 'browser-wasm'">
        <Move SourceFiles="$(WasmAppDir)/_framework/dotnet.native.wasm"
              DestinationFiles="$(WasmAppDir)/godot.wasm"
              Condition="Exists('$(WasmAppDir)/_framework/dotnet.native.wasm')"/>
        <Delete Files="$(WasmAppDir)/_framework/libgodot.wasm"/>
        <Message Importance="high" Text="TwoDog: gdext web app bundle finalized at $(WasmAppDir)"/>
    </Target>

    <!-- ============================================ -->
    <!-- Content pipeline: export the game .pck        -->
    <!-- ============================================ -->
    <!-- Runs on the HOST desktop during publish, mirroring the mono stack's
         TwoDogExportGamePack: the in-process helper (twodog.import in gdext
         mode) against the desktop gdext editor-variant libgodot, or an
         explicitly configured external editor. Incremental over the game
         project sources. -->
    <PropertyGroup Condition="'$(RuntimeIdentifier)' == 'browser-wasm'">
        <TwoDogExportPack Condition="'$(TwoDogExportPack)' == ''">true</TwoDogExportPack>
        <TwoDogWebExportPreset Condition="'$(TwoDogWebExportPreset)' == ''">Web</TwoDogWebExportPreset>
        <!-- The Godot engine JS derives all file names from the 'executable'
             config value; the default shell uses 'godot'. -->
        <TwoDogWebPackName Condition="'$(TwoDogWebPackName)' == ''">godot.pck</TwoDogWebPackName>

        <!-- The gdext stack has no 2dog.engine.targets to compute this. -->
        <TwoDogGodotProjectFullPath Condition="'$(TwoDogGodotProjectFullPath)' == '' And '$(GodotProjectDir)' != ''">$([System.IO.Path]::GetFullPath($([System.IO.Path]::Combine('$(MSBuildProjectDirectory)', '$(GodotProjectDir)'))))</TwoDogGodotProjectFullPath>

        <!-- BaseIntermediateOutputPath (not IntermediateOutputPath): defined
             early by Microsoft.Common.props, so the path is stable whether
             these targets are imported from the package or a source-checkout
             project body. -->
        <_TwoDogWebPackPath>$(BaseIntermediateOutputPath)twodog-web/$(TwoDogWebPackName)</_TwoDogWebPackPath>

        <!-- Host-OS gdext editor libgodot: the 2dog.gdextension.<host-rid>.editor
             package (same NativesVersion as this package), else the source
             checkout. Override with TwoDogGdextEditorLibGodotPath. -->
        <_TwoDogGdextHostRid Condition="$([MSBuild]::IsOSPlatform('Windows'))">win-x64</_TwoDogGdextHostRid>
        <_TwoDogGdextHostRid Condition="$([MSBuild]::IsOSPlatform('Linux'))">linux-x64</_TwoDogGdextHostRid>
        <_TwoDogGdextHostRid Condition="$([MSBuild]::IsOSPlatform('OSX'))">osx-arm64</_TwoDogGdextHostRid>
        <_TwoDogGdextEditorLibExt Condition="$([MSBuild]::IsOSPlatform('Windows'))">dll</_TwoDogGdextEditorLibExt>
        <_TwoDogGdextEditorLibExt Condition="$([MSBuild]::IsOSPlatform('Linux'))">so</_TwoDogGdextEditorLibExt>
        <_TwoDogGdextEditorLibExt Condition="$([MSBuild]::IsOSPlatform('OSX'))">dylib</_TwoDogGdextEditorLibExt>
        <_TwoDogGdextEditorPackageLib>$(NuGetPackageRoot)/2dog.gdextension.$(_TwoDogGdextHostRid).editor/$(TwoDogWebPackageVersion)/runtimes/$(_TwoDogGdextHostRid)/native/libgodot-gdext-editor.$(_TwoDogGdextEditorLibExt)</_TwoDogGdextEditorPackageLib>
        <TwoDogGdextEditorLibGodotPath Condition="'$(TwoDogGdextEditorLibGodotPath)' == '' And Exists('$(_TwoDogGdextEditorPackageLib)')">$(_TwoDogGdextEditorPackageLib)</TwoDogGdextEditorLibGodotPath>
        <!-- Source-checkout fallbacks are host-OS gated: godot/bin may hold
             several platforms' natives (CI stages them all), and the export
             must run the build machine's own editor library. -->
        <TwoDogGdextEditorLibGodotPath Condition="'$(TwoDogGdextEditorLibGodotPath)' == '' And $([MSBuild]::IsOSPlatform('Windows')) And Exists('$(MSBuildThisFileDirectory)../../../godot/bin/godot.windows.editor.x86_64.gdext_shared_library.dll')">$(MSBuildThisFileDirectory)../../../godot/bin/godot.windows.editor.x86_64.gdext_shared_library.dll</TwoDogGdextEditorLibGodotPath>
        <TwoDogGdextEditorLibGodotPath Condition="'$(TwoDogGdextEditorLibGodotPath)' == '' And $([MSBuild]::IsOSPlatform('Linux')) And Exists('$(MSBuildThisFileDirectory)../../../godot/bin/libgodot.linuxbsd.editor.x86_64.gdext_shared_library.so')">$(MSBuildThisFileDirectory)../../../godot/bin/libgodot.linuxbsd.editor.x86_64.gdext_shared_library.so</TwoDogGdextEditorLibGodotPath>
        <TwoDogGdextEditorLibGodotPath Condition="'$(TwoDogGdextEditorLibGodotPath)' == '' And $([MSBuild]::IsOSPlatform('OSX')) And Exists('$(MSBuildThisFileDirectory)../../../godot/bin/libgodot.macos.editor.arm64.gdext_shared_library.dylib')">$(MSBuildThisFileDirectory)../../../godot/bin/libgodot.macos.editor.arm64.gdext_shared_library.dylib</TwoDogGdextEditorLibGodotPath>

        <!-- Import/export helper: package tools first, source checkout second
             (mirrors 2dog.engine.targets). -->
        <TwoDogImportHelperPath Condition="'$(TwoDogImportHelperPath)' == '' And Exists('$(MSBuildThisFileDirectory)../tools/net10.0/2dog.import.dll')">$(MSBuildThisFileDirectory)../tools/net10.0/2dog.import.dll</TwoDogImportHelperPath>
        <TwoDogImportHelperPath Condition="'$(TwoDogImportHelperPath)' == '' And Exists('$(MSBuildThisFileDirectory)../../../twodog.import/bin/Release/net10.0/2dog.import.dll')">$(MSBuildThisFileDirectory)../../../twodog.import/bin/Release/net10.0/2dog.import.dll</TwoDogImportHelperPath>
        <TwoDogImportHelperPath Condition="'$(TwoDogImportHelperPath)' == '' And Exists('$(MSBuildThisFileDirectory)../../../twodog.import/bin/Debug/net10.0/2dog.import.dll')">$(MSBuildThisFileDirectory)../../../twodog.import/bin/Debug/net10.0/2dog.import.dll</TwoDogImportHelperPath>
        <_TwoDogDotNetHost Condition="'$(_TwoDogDotNetHost)' == ''">$(DOTNET_HOST_PATH)</_TwoDogDotNetHost>
        <_TwoDogDotNetHost Condition="'$(_TwoDogDotNetHost)' == ''">dotnet</_TwoDogDotNetHost>
    </PropertyGroup>

    <!-- Export incrementality inputs. Directories carrying a .gdignore are
         skipped by the Godot export (and hold a nested host's own build
         outputs - including the exported pck itself, which must never count
         as an input). -->
    <ItemGroup Condition="'$(RuntimeIdentifier)' == 'browser-wasm' And '$(TwoDogExportPack)' == 'true' And '$(TwoDogGodotProjectFullPath)' != ''">
        <_TwoDogWebGdIgnoredDirs Include="$(TwoDogGodotProjectFullPath)/**/.gdignore"/>
        <TwoDogWebExportInputs Include="$(TwoDogGodotProjectFullPath)/**/*"
                               Exclude="$(TwoDogGodotProjectFullPath)/.godot/**;$(TwoDogGodotProjectFullPath)/bin/**;$(TwoDogGodotProjectFullPath)/obj/**;$(TwoDogGodotProjectFullPath)/**/*.tmp;$(TwoDogGodotProjectFullPath)/**/.DS_Store;@(_TwoDogWebGdIgnoredDirs->'%(RootDir)%(Directory)**');$(TwoDogImportExcludes)"/>
    </ItemGroup>

    <Target Name="TwoDogGdextExportGamePack"
            BeforeTargets="Publish"
            AfterTargets="Build"
            Inputs="@(TwoDogWebExportInputs)"
            Outputs="$(_TwoDogWebPackPath)"
            Condition="'$(RuntimeIdentifier)' == 'browser-wasm' And '$(DesignTimeBuild)' != 'true' And '$(TwoDogExportPack)' == 'true' And '$(TwoDogGodotProjectFullPath)' != '' And Exists('$(TwoDogGodotProjectFullPath)/project.godot')">

        <PropertyGroup>
            <_TwoDogExportEditor>$(GodotEditor)</_TwoDogExportEditor>
            <_TwoDogExportEditor Condition="'$(_TwoDogExportEditor)' == ''">$(GODOT_EDITOR)</_TwoDogExportEditor>
            <_TwoDogCanUseHelper>false</_TwoDogCanUseHelper>
            <_TwoDogCanUseHelper Condition="'$(TwoDogImportHelperPath)' != '' And '$(TwoDogGdextEditorLibGodotPath)' != '' And Exists('$(TwoDogGdextEditorLibGodotPath)')">true</_TwoDogCanUseHelper>
            <_TwoDogWebPackFullPath>$([System.IO.Path]::GetFullPath($([System.IO.Path]::Combine('$(MSBuildProjectDirectory)', '$(_TwoDogWebPackPath)'))))</_TwoDogWebPackFullPath>
            <_TwoDogExportPresetsPath>$(TwoDogGodotProjectFullPath)/export_presets.cfg</_TwoDogExportPresetsPath>
            <_TwoDogHasWebPreset>false</_TwoDogHasWebPreset>
            <_TwoDogHasWebPreset Condition="Exists('$(_TwoDogExportPresetsPath)') And $([System.IO.File]::ReadAllText('$(_TwoDogExportPresetsPath)').Contains('name=&quot;$(TwoDogWebExportPreset)&quot;'))">true</_TwoDogHasWebPreset>
        </PropertyGroup>

        <!-- Fail with an actionable message instead of the engine's exit-1
             (whose stderr an IDE build may swallow entirely). -->
        <Error Condition="'$(_TwoDogHasWebPreset)' != 'true'"
               Text="TwoDog: web publish exports the game pck via the '$(TwoDogWebExportPreset)' export preset, which '$(_TwoDogExportPresetsPath)' does not define (or the file is missing). Add it in the Godot editor (Project &gt; Export &gt; Add &gt; Web) or point &lt;TwoDogWebExportPreset&gt; at an existing preset."/>

        <MakeDir Directories="$([System.IO.Path]::GetDirectoryName('$(_TwoDogWebPackFullPath)'))"/>

        <!-- (1) explicitly configured external editor -->
        <Exec Condition="'$(_TwoDogExportEditor)' != ''"
              Command="&quot;$(_TwoDogExportEditor)&quot; --headless --export-pack &quot;$(TwoDogWebExportPreset)&quot; &quot;$(_TwoDogWebPackFullPath)&quot; --path &quot;$(TwoDogGodotProjectFullPath)&quot;"
              IgnoreStandardErrorWarningFormat="true"/>

        <!-- (2) in-process helper against the gdext editor libgodot. Import
             first: the gdext stack has no desktop auto-import target, and
             libgodot_export_pack requires an imported project. Helper runs
             are separate processes (one engine lifetime each). -->
        <Exec Condition="'$(_TwoDogExportEditor)' == '' And '$(_TwoDogCanUseHelper)' == 'true'"
              Command="&quot;$(_TwoDogDotNetHost)&quot; exec &quot;$(TwoDogImportHelperPath)&quot; --gdext --libgodot &quot;$(TwoDogGdextEditorLibGodotPath)&quot; &quot;$(TwoDogGodotProjectFullPath)&quot;"
              IgnoreStandardErrorWarningFormat="true"/>
        <Exec Condition="'$(_TwoDogExportEditor)' == '' And '$(_TwoDogCanUseHelper)' == 'true'"
              Command="&quot;$(_TwoDogDotNetHost)&quot; exec &quot;$(TwoDogImportHelperPath)&quot; --gdext --export-pack &quot;$(TwoDogWebExportPreset)&quot; --output &quot;$(_TwoDogWebPackFullPath)&quot; --libgodot &quot;$(TwoDogGdextEditorLibGodotPath)&quot; &quot;$(TwoDogGodotProjectFullPath)&quot;"
              IgnoreStandardErrorWarningFormat="true"/>

        <Error Condition="'$(_TwoDogExportEditor)' == '' And '$(_TwoDogCanUseHelper)' != 'true'"
               Text="TwoDog: web publish needs to export '$(TwoDogGodotProjectFullPath)' as a .pck, but no export capability was found (gdext editor libgodot='$(TwoDogGdextEditorLibGodotPath)', helper='$(TwoDogImportHelperPath)'). Set &lt;GodotEditor&gt; to a Godot editor binary, or restore the 2dog.gdextension.&lt;host-rid&gt;.editor package. Set &lt;TwoDogExportPack&gt;false&lt;/TwoDogExportPack&gt; to provide the pck yourself (wwwroot/$(TwoDogWebPackName))."/>
    </Target>

    <!-- Deploy the exported pck into the app bundle. Separate from the export
         so an up-to-date (skipped) export still deploys. -->
    <Target Name="TwoDogGdextDeployPack"
            AfterTargets="TwoDogGdextWebFinalizeBundle"
            Condition="'$(RuntimeIdentifier)' == 'browser-wasm' And '$(TwoDogExportPack)' == 'true' And Exists('$(_TwoDogWebPackPath)')">
        <Copy SourceFiles="$(_TwoDogWebPackPath)"
              DestinationFiles="$(WasmAppDir)/$(TwoDogWebPackName)"
              SkipUnchangedFiles="true"/>
        <Message Importance="high" Text="TwoDog: deployed $(TwoDogWebPackName) to the app bundle"/>
    </Target>
</Project>
